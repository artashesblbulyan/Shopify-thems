{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {%- render 'stylesheets' -%}
    {{ 'template-giftcard.css' | asset_url | stylesheet_tag }}
    <link rel="stylesheet" href="{{ 'editorial.css' | asset_url }}">

    <script type="importmap">
      {
        "imports": {
          "@theme/component": "{{ 'component.js' | asset_url }}",
          "@theme/utilities": "{{ 'utilities.js' | asset_url }}",
          "@theme/qr-code-generator": "{{ 'qr-code-generator.js' | asset_url }}"
        }
      }
    </script>

    <script
      src="{{ 'qr-code-image.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>
    <script
      src="{{ 'copy-to-clipboard.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0a0a0a">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {%- assign formatted_balance = gift_card.balance | money_without_trailing_zeros | strip_html -%}

    <title>{{ 'gift_cards.issued.title' | t: value: formatted_balance, shop: shop.name }}</title>
    <meta name="description" content="{{ 'gift_cards.issued.subtext' | t }}">

    {{ content_for_header }}

    {% # theme-check-disable AssetPreload %}
    {%- unless settings.type_body_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_body_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {%- unless settings.type_subheading_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_subheading_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {%- unless settings.type_heading_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_heading_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {%- unless settings.type_accent_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_accent_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {% # theme-check-enable AssetPreload %}

    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    <script>
      (function () {
        try {
          var mode = localStorage.getItem('ed-mode') || 'day';
          document.documentElement.dataset.edMode = mode;
        } catch (e) {
          document.documentElement.dataset.edMode = 'day';
        }
      })();
    </script>

    <style>
      .ed-gift-card-page {
        min-height: 100svh;
        margin: 0;
        background: var(--ed-bg);
        color: var(--ed-fg);
        font-family: var(--ed-font-body);
      }

      .ed-gift-card {
        min-height: 100svh;
        display: grid;
        grid-template-columns: minmax(0, 5fr) minmax(320px, 4fr);
        gap: 48px;
        align-items: center;
        padding: 48px;
      }

      .ed-gift-card__brand {
        position: fixed;
        top: 24px;
        left: 32px;
        z-index: 2;
        color: var(--ed-fg);
        text-decoration: none;
        font-family: var(--ed-font-display);
        font-style: italic;
        font-size: 28px;
        letter-spacing: -0.03em;
      }

      .ed-gift-card__brand img {
        max-width: 160px;
        height: auto;
      }

      .ed-gift-card__hero {
        display: flex;
        flex-direction: column;
        gap: 20px;
        max-width: 760px;
      }

      .ed-gift-card__title {
        font-family: var(--ed-font-display);
        font-weight: 400;
        font-size: clamp(64px, 11vw, 170px);
        line-height: 0.88;
        letter-spacing: -0.045em;
        margin: 0;
        color: var(--ed-fg);
        text-wrap: balance;
      }

      .ed-gift-card__copy {
        max-width: 34em;
        margin: 0;
        color: var(--ed-muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .ed-gift-card__panel {
        border: 1px solid var(--ed-line);
        border-radius: var(--ed-radius-card);
        background:
          linear-gradient(135deg, color-mix(in srgb, var(--ed-accent) 16%, transparent), transparent 38%),
          var(--ed-card);
        padding: 28px;
        box-shadow: var(--ed-shadow-card);
      }

      .ed-gift-card__visual {
        aspect-ratio: 16 / 10;
        border: 1px solid var(--ed-line);
        border-radius: var(--ed-radius);
        background: var(--ed-bg);
        display: grid;
        place-items: center;
        overflow: hidden;
        margin-bottom: 28px;
      }

      .ed-gift-card__image {
        max-width: 70%;
        max-height: 70%;
        object-fit: contain;
      }

      .ed-gift-card__balance {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 18px;
        padding-bottom: 22px;
        border-bottom: 1px solid var(--ed-line);
      }

      .ed-gift-card__balance h2 {
        font-family: var(--ed-font-display);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(42px, 7vw, 78px);
        line-height: 0.9;
        margin: 0;
      }

      .ed-gift-card__badge {
        margin: 0;
        padding: 6px 10px;
        border-radius: var(--ed-pill);
        background: var(--ed-accent);
        color: #0a0a0a;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .ed-gift-card__details {
        display: grid;
        gap: 18px;
        padding: 24px 0;
      }

      .ed-gift-card__text {
        margin: 0;
        color: var(--ed-muted);
        font-size: 13px;
        line-height: 1.55;
      }

      .ed-gift-card__code {
        margin: 6px 0 0;
        font-family: var(--ed-font-body);
        font-size: clamp(20px, 3vw, 30px);
        letter-spacing: 0.08em;
        color: var(--ed-fg);
        overflow-wrap: anywhere;
      }

      .ed-gift-card__qr {
        display: inline-grid;
        place-items: center;
        width: 92px;
        height: 92px;
        border: 1px solid var(--ed-line);
        border-radius: var(--ed-radius);
        background: #fff;
        padding: 10px;
      }

      .ed-gift-card__actions {
        display: grid;
        gap: 10px;
      }

      .ed-gift-card__wallet {
        display: flex;
        justify-content: center;
        padding: 10px;
        border: 1px solid var(--ed-line);
        border-radius: var(--ed-pill);
      }

      .ed-gift-card__copy-button,
      .ed-gift-card__shop {
        width: 100%;
        justify-content: center;
      }

      .ed-gift-card__copy-button {
        border: 1px solid var(--ed-fg);
      }

      @media (max-width: 900px) {
        .ed-gift-card {
          grid-template-columns: 1fr;
          padding: 96px 20px 32px;
          gap: 32px;
        }

        .ed-gift-card__brand {
          top: 20px;
          left: 20px;
        }

        .ed-gift-card__panel {
          padding: 20px;
        }
      }
    </style>
  </head>

  <body class="gift-card ed-gift-card-page">
    <a class="ed-gift-card__brand" href="{{ shop.url }}" target="_blank" rel="noopener">
      {%- if settings.logo != blank -%}
        {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
        {{ settings.logo | image_url: width: 320 | image_tag: alt: logo_alt, loading: 'eager' }}
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <main class="ed-gift-card">
      <section class="ed-gift-card__hero" aria-labelledby="gift-card-title">
        <div class="ed-eyebrow">Gift card</div>
        <h1 id="gift-card-title" class="ed-gift-card__title">
          A little <em>light</em>, sent forward.
        </h1>
        <p class="ed-gift-card__copy">
          Use this code at checkout. Keep it somewhere safe, or add it to your wallet if the option is available.
        </p>
      </section>

      <section class="ed-gift-card__panel" aria-label="{{ 'gift_cards.issued.title' | t: value: formatted_balance, shop: shop.name | escape }}">
        <div class="ed-gift-card__visual">
          {%- if settings.logo != blank -%}
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {{ settings.logo | image_url: width: 420 | image_tag: class: 'ed-gift-card__image', alt: logo_alt }}
          {%- else -%}
            <img
              class="ed-gift-card__image"
              src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
              alt=""
              height="200"
              width="334"
              loading="eager"
            >
          {%- endif -%}
        </div>

        <div class="ed-gift-card__balance">
          <h2>{{ gift_card.balance | money_with_currency }}</h2>
          {%- if gift_card.enabled == false or gift_card.expired -%}
            <p class="ed-gift-card__badge">{{ 'gift_cards.issued.expired' | t }}</p>
          {%- endif -%}
        </div>

        <div class="ed-gift-card__details">
          {%- if gift_card.expires_on -%}
            {%- assign gift_card_expiration_date = gift_card.expires_on | date: '%B %e, %Y' -%}
            <p class="ed-gift-card__text">
              {{ 'gift_cards.issued.expiration_date' | t: expires_on: gift_card_expiration_date }}
            </p>
          {%- endif -%}

          <div>
            <p class="ed-gift-card__text">{{ 'gift_cards.issued.how_to_use_gift_card' | t }}</p>
            <h3 class="ed-gift-card__code">{{ gift_card.code | format_code }}</h3>
          </div>

          <qr-code-image
            class="ed-gift-card__qr"
            data-identifier="{{ gift_card.qr_identifier }}"
            width="72"
            height="72"
            alt="{{ 'gift_cards.issued.qr_image_alt' | t }}"
          ></qr-code-image>
        </div>

        <div class="ed-gift-card__actions">
          {%- if gift_card.pass_url -%}
            <a href="{{ gift_card.pass_url }}" class="ed-gift-card__wallet">
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                width="120"
                height="40"
                alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t }}"
                loading="lazy"
              >
            </a>
          {%- endif -%}

          <copy-to-clipboard-component text-to-copy="{{ gift_card.code }}">
            <span
              class="form__message visually-hidden"
              ref="copySuccessMessage"
              role="status"
            >
              <span class="svg-wrapper icon-success">
                {{ 'icon-checkmark.svg' | inline_asset_content }}
              </span>
              {{ 'gift_cards.issued.copy_code_success' | t }}
            </span>
            <button
              class="ed-btn ed-btn--solid ed-gift-card__copy-button"
              on:click="/copyToClipboard"
            >
              {{ 'gift_cards.issued.copy_code' | t }}
            </button>
          </copy-to-clipboard-component>

          <a
            href="{{ shop.url }}"
            class="ed-btn ed-btn--ghost ed-gift-card__shop"
            target="_blank"
            rel="noopener"
            aria-describedby="a11y-new-window-message"
          >
            {{ 'gift_cards.issued.shop_link' | t }}
          </a>
        </div>
      </section>
    </main>

    <div hidden>
      <span id="a11y-new-window-message">{{ 'accessibility.new_window' | t }}</span>
    </div>
  </body>
</html>
