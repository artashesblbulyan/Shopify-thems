{%- paginate collections by 24 -%}

<section class="ed-list-collections ed-section">
  <header class="ed-list-collections__head ed-reveal-stagger">
    <div class="ed-list-collections__index">
      <span>{{ section.settings.index_number | default: '01' }}</span>
      <hr>
      <span>{{ section.settings.index_label | default: 'Collections' }}</span>
    </div>
    <h1 class="ed-display ed-list-collections__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.description != blank -%}
      <p class="ed-list-collections__desc">{{ section.settings.description }}</p>
    {%- endif -%}
    <div class="ed-list-collections__meta">
      <span>{{ collections.size }} {{ collections.size | pluralize: 'collection', 'collections' }}</span>
      <span>/</span>
      <span>Page {{ paginate.current_page }} of {{ paginate.pages | default: 1 }}</span>
    </div>
  </header>

  {%- if collections.size > 0 -%}
    <div class="ed-list-collections__grid ed-reveal-stagger">
      {%- for collection in collections -%}
        {%- assign idx = forloop.index | prepend: '0' | slice: -2, 2 -%}
        {%- assign collection_image = collection.featured_image | default: collection.image | default: collection.products.first.featured_image -%}
        <a class="ed-list-collections__card" href="{{ collection.url }}">
          <div class="ed-list-collections__media">
            {%- if collection_image -%}
              {{ collection_image | image_url: width: 1000 | image_tag:
                loading: 'lazy',
                widths: '360, 540, 720, 1000',
                sizes: '(max-width: 720px) 100vw, 33vw',
                alt: collection_image.alt | default: collection.title,
                class: 'ed-list-collections__photo'
              }}
            {%- endif -%}
            <span class="ed-list-collections__idx">{{ idx }}</span>
            <span class="ed-list-collections__count">{{ collection.products_count }} pieces</span>
          </div>
          <div class="ed-list-collections__content">
            <h2>{{ collection.title }}</h2>
            {%- if collection.description != blank -%}
              <p>{{ collection.description | strip_html | truncatewords: 18 }}</p>
            {%- endif -%}
            <span class="ed-list-collections__link">Explore <span aria-hidden="true">-&gt;</span></span>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="ed-list-collections__pagination" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a class="ed-btn ed-btn--ghost" href="{{ paginate.previous.url }}">&lt;- Previous</a>
        {%- endif -%}
        <span>Page {{ paginate.current_page }} / {{ paginate.pages }}</span>
        {%- if paginate.next -%}
          <a class="ed-btn ed-btn--ghost" href="{{ paginate.next.url }}">Next -&gt;</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- else -%}
    <div class="ed-list-collections__empty">
      <p>No collections are published yet.</p>
      <a class="ed-btn ed-btn--solid" href="{{ routes.all_products_collection_url }}">
        Shop all <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
      </a>
    </div>
  {%- endif -%}
</section>

{%- endpaginate -%}

{% stylesheet %}
  .ed-list-collections {
    padding: 80px 32px 96px;
  }

  .ed-list-collections__head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 960px;
    margin-bottom: 52px;
  }

  .ed-list-collections__index {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }

  .ed-list-collections__index span:first-child {
    color: var(--ed-fg);
    padding: 4px 10px;
    border: 1px solid var(--ed-line-strong);
    border-radius: var(--ed-pill);
  }

  .ed-list-collections__index hr {
    width: 40px;
    height: 1px;
    background: var(--ed-line);
    border: none;
    margin: 0;
  }

  .ed-list-collections__title {
    font-family: var(--ed-font-display);
    font-weight: 400;
    font-size: clamp(56px, 10vw, 150px);
    line-height: 0.9;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .ed-list-collections__desc {
    font-family: var(--ed-font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ed-muted);
    max-width: 36em;
    margin: 0;
  }

  .ed-list-collections__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid var(--ed-line);
    margin-top: 8px;
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }

  .ed-list-collections__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .ed-list-collections__card {
    display: flex;
    flex-direction: column;
    color: var(--ed-fg);
    text-decoration: none;
    border-top: 1px solid var(--ed-line);
    padding-top: 18px;
  }

  .ed-list-collections__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--ed-radius-card);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--ed-accent) 14%, transparent), transparent 42%),
      var(--ed-card);
    border: 1px solid var(--ed-line);
    margin-bottom: 18px;
  }

  .ed-list-collections__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ed-ease);
  }

  .ed-list-collections__card:hover .ed-list-collections__photo {
    transform: scale(1.05);
  }

  .ed-list-collections__idx,
  .ed-list-collections__count {
    position: absolute;
    top: 14px;
    font-family: var(--ed-font-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: var(--ed-pill);
    backdrop-filter: blur(8px);
  }

  .ed-list-collections__idx {
    left: 14px;
    background: color-mix(in srgb, var(--ed-bg) 80%, transparent);
    color: var(--ed-fg);
    border: 1px solid var(--ed-line);
  }

  .ed-list-collections__count {
    right: 14px;
    background: var(--ed-accent);
    color: #0a0a0a;
  }

  .ed-list-collections__content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ed-list-collections__content h2 {
    font-family: var(--ed-font-display);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1;
    letter-spacing: 0;
    margin: 0;
  }

  .ed-list-collections__content p {
    font-family: var(--ed-font-body);
    font-size: 13px;
    line-height: 1.55;
    color: var(--ed-muted);
    margin: 0;
    max-width: 28em;
  }

  .ed-list-collections__link {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    margin-top: 8px;
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }

  .ed-list-collections__card:hover .ed-list-collections__link {
    color: var(--ed-accent);
  }

  .ed-list-collections__pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--ed-line);
    font-family: var(--ed-font-body);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }

  .ed-list-collections__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 80px 24px;
    border: 1px dashed var(--ed-line);
    border-radius: var(--ed-radius-card);
    text-align: center;
    color: var(--ed-muted);
  }

  @media (max-width: 1100px) {
    .ed-list-collections__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .ed-list-collections {
      padding: 60px 20px 72px;
    }

    .ed-list-collections__grid {
      grid-template-columns: 1fr;
    }

    .ed-list-collections__pagination {
      align-items: flex-start;
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collections - Editorial",
  "tag": "section",
  "class": "section-ed-list-collections",
  "settings": [
    { "type": "text", "id": "index_number", "label": "Index number", "default": "01" },
    { "type": "text", "id": "index_label", "label": "Index label", "default": "Collections" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>All <em>collections</em>.</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Browse the complete studio catalog by mood, room, and silhouette."
    }
  ],
  "presets": [
    { "name": "Collections - Editorial" }
  ],
  "enabled_on": {
    "templates": ["list-collections"]
  }
}
{% endschema %}
