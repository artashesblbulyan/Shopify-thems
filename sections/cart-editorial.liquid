<section
  class="ed-cart ed-section"
  data-ed-cart-section
  data-section-id="{{ section.id }}"
  data-cart-url="{{ routes.cart_url }}"
  data-cart-change-url="{{ routes.cart_change_url | escape }}"
>
  <header class="ed-cart__head ed-reveal-stagger">
    <div class="ed-cart__index">
      <span>01</span>
      <hr>
      <span>Bag</span>
    </div>
    <h1 class="ed-display ed-cart__title">Your <em>bag</em>.</h1>
    <p class="ed-cart__count">
      {%- if cart.item_count > 0 -%}
        {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }} / {{ cart.total_price | money }}
      {%- else -%}
        Empty for now
      {%- endif -%}
    </p>
  </header>

  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate class="ed-cart__form" id="cart-form">
      <div class="ed-cart__items ed-reveal-stagger">
        {%- for item in cart.items -%}
          <article class="ed-cart__item" data-ed-cart-line="{{ forloop.index }}">
            <a class="ed-cart__item-img" href="{{ item.url }}">
              {%- if item.image -%}
                {{ item.image | image_url: width: 320 | image_tag:
                  loading: 'lazy',
                  alt: item.title,
                  class: 'ed-cart__item-photo'
                }}
              {%- endif -%}
            </a>
            <div class="ed-cart__item-meta">
              <div class="ed-cart__item-row">
                <div>
                  <a class="ed-cart__item-title" href="{{ item.url }}">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="ed-cart__item-variant">{{ item.variant.title }}</div>
                  {%- endunless -%}
                </div>
                <div class="ed-cart__item-price">{{ item.final_line_price | money }}</div>
              </div>
              <div class="ed-cart__item-bottom">
                <div class="ed-cart__qty">
                  <button type="button" data-ed-cart-qty-button data-ed-cart-step="-1" data-line="{{ forloop.index }}" data-key="{{ item.key | escape }}" aria-label="Decrease quantity for {{ item.product.title | escape }}">-</button>
                  <input
                    type="number"
                    name="updates[{{ item.key }}]"
                    value="{{ item.quantity }}"
                    min="0"
                    inputmode="numeric"
                    data-ed-cart-qty-input
                    data-line="{{ forloop.index }}"
                    data-key="{{ item.key | escape }}"
                    aria-label="Quantity for {{ item.product.title | escape }}"
                  >
                  <button type="button" data-ed-cart-qty-button data-ed-cart-step="1" data-line="{{ forloop.index }}" data-key="{{ item.key | escape }}" aria-label="Increase quantity for {{ item.product.title | escape }}">+</button>
                </div>
                <a href="{{ item.url_to_remove }}" class="ed-cart__item-remove" data-ed-cart-remove data-line="{{ forloop.index }}" data-key="{{ item.key | escape }}" aria-label="Remove {{ item.product.title | escape }}">Remove</a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>

      <aside class="ed-cart__summary">
        <h2 class="ed-cart__summary-title">Summary</h2>
        <div class="ed-cart__summary-row">
          <span>Subtotal</span>
          <span>{{ cart.items_subtotal_price | money }}</span>
        </div>
        {%- if cart.cart_level_discount_applications.size > 0 -%}
          {%- for discount in cart.cart_level_discount_applications -%}
            <div class="ed-cart__summary-row ed-cart__summary-discount">
              <span>{{ discount.title }}</span>
              <span>-{{ discount.total_allocated_amount | money }}</span>
            </div>
          {%- endfor -%}
        {%- endif -%}
        <div class="ed-cart__summary-row ed-cart__summary-total">
          <span>Total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p class="ed-cart__summary-note">Shipping &amp; taxes calculated at checkout.</p>

        <textarea name="note" placeholder="Add a note (optional)" aria-label="Cart note" class="ed-cart__note">{{ cart.note }}</textarea>

        <button type="submit" name="update" class="ed-btn ed-btn--ghost ed-cart__update">Update bag</button>
        <button type="submit" name="checkout" class="ed-btn ed-btn--solid ed-cart__checkout">
          Checkout / {{ cart.total_price | money }}
          <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
        </button>
        <a class="ed-cart__continue" href="{{ routes.all_products_collection_url }}">&lt;- Continue shopping</a>
      </aside>
    </form>
  {%- else -%}
    <div class="ed-cart__empty ed-reveal">
      <p>Your bag is empty.</p>
      <a class="ed-btn ed-btn--solid" href="{{ routes.all_products_collection_url }}">
        Shop now <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
      </a>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .ed-cart {
    padding: 64px 32px 96px;
  }
  .ed-cart__head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 48px;
  }
  .ed-cart__index {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }
  .ed-cart__index span:first-child {
    color: var(--ed-fg);
    padding: 4px 10px;
    border: 1px solid var(--ed-line-strong);
    border-radius: var(--ed-pill);
  }
  .ed-cart__index hr {
    width: 40px; height: 1px; background: var(--ed-line); border: none; margin: 0;
  }
  .ed-cart__title {
    font-family: var(--ed-font-display);
    font-weight: 400;
    font-size: clamp(48px, 8vw, 120px);
    line-height: 0.92;
    letter-spacing: 0;
  }
  .ed-cart__count {
    font-family: var(--ed-font-body);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }

  .ed-cart__form {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 48px;
    align-items: start;
  }
  .ed-cart__items {
    display: flex;
    flex-direction: column;
  }
  .ed-cart__item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 20px;
    padding: 28px 0;
    border-top: 1px solid var(--ed-line);
  }
  .ed-cart__item:last-child {
    border-bottom: 1px solid var(--ed-line);
  }
  .ed-cart__item-img {
    border-radius: var(--ed-radius);
    overflow: hidden;
    background: var(--ed-card);
    aspect-ratio: 1;
    display: block;
    border: 1px solid var(--ed-line);
  }
  .ed-cart__item-photo { width: 100%; height: 100%; object-fit: cover; }
  .ed-cart__item-meta {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 12px;
  }
  .ed-cart__item-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }
  .ed-cart__item-title {
    font-family: var(--ed-font-display);
    font-size: 22px;
    color: var(--ed-fg);
    text-decoration: none;
    line-height: 1.15;
  }
  .ed-cart__item-variant {
    font-family: var(--ed-font-body);
    font-size: 12px;
    color: var(--ed-muted);
    margin-top: 4px;
    letter-spacing: 0.04em;
  }
  .ed-cart__item-price {
    font-family: var(--ed-font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--ed-fg);
    white-space: nowrap;
  }
  .ed-cart__item-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .ed-cart__qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-pill);
    padding: 4px;
  }
  .ed-cart__qty :is(a, button) {
    width: 28px; height: 28px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--ed-fg);
    font: inherit;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s var(--ed-ease);
  }
  .ed-cart__qty :is(a, button):hover { background: color-mix(in srgb, var(--ed-fg) 10%, transparent); }
  .ed-cart__qty :is(a, button):disabled { cursor: progress; opacity: 0.55; }
  .ed-cart__qty input {
    width: 36px;
    min-width: 36px;
    min-height: 28px;
    text-align: center;
    background: transparent;
    border: none;
    color: var(--ed-fg);
    font-family: var(--ed-font-body);
    font-size: 14px;
    font-style: normal;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
    appearance: textfield;
    -moz-appearance: textfield;
  }
  .ed-cart__qty input:focus {
    outline: none;
  }
  .ed-cart__qty input::-webkit-outer-spin-button,
  .ed-cart__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .ed-cart__item-remove {
    font-family: var(--ed-font-body);
    font-size: 12px;
    color: var(--ed-muted);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s var(--ed-ease);
  }
  .ed-cart__item-remove:hover { color: var(--ed-fg); }

  .ed-cart__summary {
    position: sticky;
    top: 90px;
    padding: 32px;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-radius-card);
    background: var(--ed-card);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .ed-cart__summary-title {
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ed-muted);
    margin: 0 0 6px;
    font-weight: 500;
  }
  .ed-cart__summary-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--ed-font-body);
    font-size: 14px;
    color: var(--ed-fg);
    padding: 6px 0;
  }
  .ed-cart__summary-discount { color: var(--ed-accent); }
  .ed-cart__summary-total {
    padding-top: 14px;
    border-top: 1px solid var(--ed-line);
    font-family: var(--ed-font-display);
    font-size: 22px;
    font-style: italic;
  }
  .ed-cart__summary-note {
    font-family: var(--ed-font-body);
    font-size: 11px;
    color: var(--ed-muted);
    margin: 0 0 8px;
  }
  .ed-cart__note {
    background: transparent;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-radius);
    color: var(--ed-fg);
    padding: 12px;
    font: inherit;
    font-size: 13px;
    min-height: 80px;
    width: 100%;
    resize: vertical;
    transition: border-color 0.2s var(--ed-ease);
  }
  .ed-cart__note:focus {
    outline: none;
    border-color: var(--ed-fg);
  }
  .ed-cart__update, .ed-cart__checkout {
    width: 100%;
    justify-content: center;
    padding: 16px;
  }
  .ed-cart__checkout {
    justify-content: space-between;
    padding: 18px 24px;
  }
  .ed-cart__continue {
    text-align: center;
    font-family: var(--ed-font-body);
    font-size: 12px;
    color: var(--ed-muted);
    text-decoration: none;
    padding: 8px;
    transition: color 0.2s var(--ed-ease);
  }
  .ed-cart__continue:hover { color: var(--ed-fg); }

  .ed-cart__empty {
    text-align: center;
    padding: 96px 24px;
    border: 1px dashed var(--ed-line);
    border-radius: var(--ed-radius-card);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    color: var(--ed-muted);
  }

  .ed-cart.is-updating {
    cursor: progress;
  }

  .ed-cart.is-updating .ed-cart__items,
  .ed-cart.is-updating .ed-cart__summary {
    opacity: 0.72;
  }

  @media (max-width: 900px) {
    .ed-cart__form { grid-template-columns: 1fr; gap: 32px; }
    .ed-cart__summary { position: static; }
    .ed-cart { padding: 48px 20px 64px; }
    .ed-cart__item { grid-template-columns: 90px 1fr; gap: 14px; }
    .ed-cart__item-title { font-size: 18px; }
    .ed-cart__item-price { font-size: 18px; }
  }
{% endstylesheet %}

<script src="{{ 'cart-editorial.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Cart - Editorial",
  "tag": "section",
  "class": "section-ed-cart",
  "settings": [],
  "presets": [ { "name": "Cart - Editorial" } ],
  "enabled_on": { "templates": ["cart"] }
}
{% endschema %}
