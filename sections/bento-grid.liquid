{%- liquid
  assign collection = collections[section.settings.collection]
  assign products = collection.products | slice: 0, 6
  assign size_pattern = 'tall,wide,sq,lg,lg,lg' | split: ','
-%}

<section class="ed-bento ed-section" id="ed-bento-{{ section.id }}">
  <header class="ed-bento__head ed-reveal-stagger">
    <div class="ed-bento__intro">
      <div class="ed-eyebrow">{{ section.settings.index_number }} / {{ section.settings.index_label }}</div>
      <h2 class="ed-display ed-bento__title">{{ section.settings.heading }}</h2>
    </div>

    <div class="ed-bento__aside">
      {%- if section.settings.view_all_label != blank -%}
        <a class="ed-btn ed-btn--ghost ed-bento__link" href="{{ section.settings.view_all_link | default: collection.url }}">
          {{ section.settings.view_all_label }}
          <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
        </a>
      {%- endif -%}
    </div>
  </header>

  {%- if products.size > 0 -%}
    <div class="ed-bento__grid ed-reveal-stagger">
      {%- for product in products -%}
        {%- liquid
          assign size_class = size_pattern[forloop.index0] | default: 'lg'
          assign hover_image = product.images[1]
          assign badge_text = blank
          if product.compare_at_price > product.price
            assign badge_text = 'Sale'
          elsif product.available == false
            assign badge_text = 'Sold out'
          endif
        -%}
        <a class="ed-bento__card ed-bento__card--{{ size_class }} ed-bento__card--v{{ forloop.index | modulo: 4 | plus: 1 }}{% if hover_image != blank %} ed-has-hover-image{% endif %}"
           href="{{ product.url }}"
           aria-label="{{ product.title | escape }}">
          <div class="ed-bento__img">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 1000 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 900, 1000',
                sizes: '(max-width: 900px) 50vw, 33vw',
                alt: product.featured_image.alt | default: product.title,
                class: 'ed-bento__photo ed-bento__photo--primary'
              }}
            {%- endif -%}
            {%- if hover_image != blank -%}
              <span
                class="ed-bento__hover-image"
                style="--ed-hover-image: url('{{ hover_image | image_url: width: 1000 }}');"
                aria-hidden="true"
              ></span>
            {%- endif -%}
            {%- if badge_text != blank -%}
              <span class="ed-bento__badge">{{ badge_text }}</span>
            {%- endif -%}
          </div>
          <div class="ed-bento__meta">
            <div class="ed-bento__info">
              <div class="ed-bento__title-line">{{ product.title }}</div>
              <div class="ed-bento__price-row">
                <span class="ed-bento__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="ed-bento__price-old">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
            </div>
            <div class="ed-bento__hover-cta">
              <span>View product</span>
              <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="ed-bento__empty">Select a collection in the theme editor to populate this section.</p>
  {%- endif -%}
</section>

{% stylesheet %}
  .ed-bento {
    padding: 88px 32px;
  }
  .ed-bento__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    align-items: end;
    gap: 28px;
    margin-bottom: 34px;
  }
  .ed-bento__intro {
    min-width: 0;
  }
  .ed-bento__title {
    font-size: clamp(46px, 7vw, 112px);
    line-height: 0.88;
    max-width: 12.5ch;
    margin-top: 14px;
    text-wrap: balance;
  }
  .ed-bento__aside {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }
  .ed-bento__desc {
    margin: 0;
    max-width: 34em;
    color: var(--ed-muted);
    font-family: var(--ed-font-body);
    font-size: 14px;
    line-height: 1.55;
  }
  .ed-bento__summary {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--ed-muted);
    font-family: var(--ed-font-body);
    font-size: 10px;
    font-weight: 750;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }
  .ed-bento__summary span {
    padding: 6px 10px;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-pill);
    background: color-mix(in srgb, var(--ed-card) 72%, transparent);
  }
  .ed-bento__link {
    position: relative;
    width: max-content;
    color: var(--ed-fg);
    text-decoration: none;
  }
  .ed-bento__link::after {
    display: none;
  }
  .ed-bento__link:hover::after {
    display: none;
  }
  .ed-bento__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-auto-rows: auto;
    gap: 12px;
  }
  .ed-bento__card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: transparent;
    border-radius: 0;
    overflow: visible;
    transition: transform 0.45s var(--ed-ease), background 0.3s var(--ed-ease),
      box-shadow 0.45s var(--ed-ease);
    isolation: isolate;
    text-decoration: none;
    color: var(--ed-fg);
    box-shadow: none;
  }
  .ed-bento__card:hover {
    transform: translateY(-4px);
    box-shadow: none;
  }
  .ed-bento__card--tall,
  .ed-bento__card--wide,
  .ed-bento__card--sq,
  .ed-bento__card--lg {
    grid-column: span 1;
    grid-row: span 1;
  }

  .ed-bento__img {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-radius-card);
    margin-bottom: 12px;
    background:
      radial-gradient(ellipse 55% 45% at 60% 35%, rgba(253,198,86,0.4) 0%, transparent 65%),
      linear-gradient(160deg, #2a2520, #0c0a08);
  }
  .ed-bento__card--v2 .ed-bento__img { background: radial-gradient(ellipse 60% 50% at 30% 65%, rgba(231,166,58,0.28) 0%, transparent 60%), linear-gradient(135deg, #1c1712, #0c0a08); }
  .ed-bento__card--v3 .ed-bento__img { background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.18) 0%, transparent 50%), linear-gradient(180deg, #1c1c1c, #050505); }
  .ed-bento__card--v4 .ed-bento__img { background: radial-gradient(ellipse 40% 60% at 50% 40%, rgba(253,198,86,0.5) 0%, transparent 55%), linear-gradient(135deg, #2d251a, #0c0a08); }

  .ed-bento__photo {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    transition: opacity 0.42s var(--ed-ease), transform 0.7s var(--ed-ease), filter 0.4s var(--ed-ease);
    filter: brightness(0.85) saturate(0.95);
  }
  .ed-bento__photo--primary {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
    z-index: 0;
  }
  .ed-bento__hover-image {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
    background-image: var(--ed-hover-image);
    background-size: cover;
    background-position: center;
    opacity: 0;
    visibility: hidden;
    transform: scale(1.035);
    filter: brightness(0.85) saturate(0.95);
    transition: opacity 0.42s var(--ed-ease), visibility 0.42s var(--ed-ease), transform 0.7s var(--ed-ease), filter 0.4s var(--ed-ease);
    pointer-events: none;
  }
  .ed-bento__card:not(.ed-has-hover-image):hover .ed-bento__photo {
    transform: scale(1.07);
    filter: brightness(1) saturate(1.05);
  }
  .ed-bento__card.ed-has-hover-image:hover .ed-bento__photo--primary {
    opacity: 1 !important;
    visibility: visible;
    transform: scale(1.02);
    z-index: 0;
  }
  .ed-bento__card.ed-has-hover-image:hover .ed-bento__hover-image {
    opacity: 1;
    visibility: visible;
    transform: scale(1.08);
    filter: brightness(1) saturate(1.05);
  }
  html[data-ed-mode="day"] .ed-bento__img {
    background:
      radial-gradient(ellipse 55% 45% at 60% 35%, rgba(253,198,86,0.6) 0%, transparent 65%),
      linear-gradient(160deg, #b8aea0, #d4cfc4);
  }
  html[data-ed-mode="day"] .ed-bento__photo {
    filter: brightness(1) saturate(1);
  }
  html[data-ed-mode="day"] .ed-bento__hover-image {
    filter: brightness(1) saturate(1);
  }

  .ed-bento__meta {
    position: relative;
    z-index: 2;
    padding: 4px 4px 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 6px;
    height: auto;
    pointer-events: none;
  }
  .ed-bento__card-idx,
  .ed-bento__badge {
    position: absolute;
    top: 12px;
    z-index: 2;
    border-radius: var(--ed-pill);
    font-family: var(--ed-font-body);
    font-size: 10px;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 10px;
  }
  .ed-bento__card-idx {
    left: 12px;
    background: color-mix(in srgb, var(--ed-bg) 78%, transparent);
    color: var(--ed-fg);
    border: 1px solid var(--ed-line);
    backdrop-filter: blur(10px);
    font-feature-settings: "tnum";
  }
  .ed-bento__badge {
    right: 12px;
    background: var(--ed-accent);
    color: var(--ed-ink);
  }
  .ed-bento__info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .ed-bento__title-line {
    font-family: var(--ed-font-body);
    font-size: 14px;
    font-weight: 750;
    line-height: 1.25;
    max-width: 22ch;
  }
  .ed-bento__price-row {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    text-align: right;
  }
  .ed-bento__price {
    font-family: var(--ed-font-body);
    font-size: 15px;
    font-weight: 850;
    letter-spacing: -0.035em;
    white-space: nowrap;
  }
  .ed-bento__price-old {
    font-family: var(--ed-font-body);
    font-size: 12px;
    color: var(--ed-muted);
    text-decoration: line-through;
  }
  .ed-bento__hover-cta {
    display: none;
  }
  .ed-bento__card:hover .ed-bento__hover-cta {
    display: none;
  }
  .ed-bento__card:hover .ed-bento__info {
    opacity: 1;
    transform: none;
    transition: opacity 0.3s var(--ed-ease), transform 0.3s var(--ed-ease);
  }
  .ed-bento__info {
    transition: opacity 0.3s var(--ed-ease), transform 0.3s var(--ed-ease);
  }
  .ed-bento__empty {
    color: var(--ed-muted);
    font-family: var(--ed-font-body);
    text-align: center;
    padding: 60px;
    border: 1px dashed var(--ed-line);
    border-radius: var(--ed-radius-card);
  }
  @media (max-width: 1100px) {
    .ed-bento__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); grid-auto-rows: auto; }
    .ed-bento__card--tall,
    .ed-bento__card--wide,
    .ed-bento__card--sq,
    .ed-bento__card--lg {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
  @media (max-width: 720px) {
    .ed-bento { padding: 64px 20px; }
    .ed-bento__head { grid-template-columns: 1fr; gap: 20px; margin-bottom: 26px; }
    .ed-bento__title { font-size: clamp(42px, 16vw, 72px); }
    .ed-bento__desc { font-size: 13px; }
    .ed-bento__grid { grid-template-columns: 1fr 1fr; grid-auto-rows: auto; gap: 10px; }
    .ed-bento__card--tall, .ed-bento__card--wide, .ed-bento__card--sq, .ed-bento__card--lg { grid-column: span 1; grid-row: span 1; }
    .ed-bento__info { flex-direction: column; gap: 4px; }
    .ed-bento__price-row { align-items: flex-start; text-align: left; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bento - Featured",
  "tag": "section",
  "class": "section-ed-bento",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "index_number", "label": "Index number", "default": "02" },
    { "type": "text", "id": "index_label", "label": "Index label", "default": "Featured" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Make your workspace <em>yours</em>.</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A tight edit of standout pieces selected for easy scanning and confident shopping."
    },
    { "type": "header", "content": "View all" },
    { "type": "text", "id": "view_all_label", "label": "Label", "default": "View all" },
    { "type": "url", "id": "view_all_link", "label": "Link" },
    { "type": "header", "content": "Source" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [
    { "name": "Bento - Featured" }
  ]
}
{% endschema %}
