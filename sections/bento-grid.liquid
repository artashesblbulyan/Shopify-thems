{%- liquid
  assign collection = collections[section.settings.collection]
  assign products = collection.products | slice: 0, 6
  assign intro_text = section.settings.description | default: collection.description
  assign shop_url = section.settings.view_all_link | default: collection.url | default: routes.all_products_collection_url
  assign visual_image = section.settings.image | default: collection.image
  if visual_image == blank and products.first != blank
    assign visual_image = products.first.featured_image
  endif
  assign meta_left = section.settings.meta_left
  if meta_left == blank and collection != blank
    assign meta_left = collection.products_count | append: ' pieces'
  endif
  assign meta_right = section.settings.meta_right | default: collection.title | default: 'Curated online'
-%}

<section class="sf-collection-split ed-section{% if section.settings.reverse %} sf-collection-split--reverse{% endif %}" id="sf-collection-split-{{ section.id }}">
  <div class="sf-collection-split__left ed-reveal ed-reveal--lr">
    <div>
      <div class="ed-eyebrow">{{ section.settings.index_number }} / {{ section.settings.index_label }}</div>
      <h2 class="ed-display sf-collection-split__title">{{ section.settings.heading }}</h2>
    </div>

    {%- if intro_text != blank -%}
      <p class="sf-collection-split__quote">{{ intro_text | strip_html }}</p>
    {%- endif -%}

    {%- if section.settings.view_all_label != blank -%}
      <div class="sf-collection-split__cta">
        <a class="ed-btn ed-btn--solid" href="{{ shop_url }}">
          {{ section.settings.view_all_label }}
          <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
        </a>
      </div>
    {%- endif -%}

    <div class="sf-collection-split__meta">
      <span>{{ meta_left | default: 'Warm room edits' }}</span>
      <span>{{ meta_right }}</span>
    </div>
  </div>

  <a class="sf-collection-split__right ed-reveal" href="{{ shop_url }}" aria-label="{{ section.settings.view_all_label | default: collection.title | escape }}">
    {%- if visual_image != blank -%}
      {{ visual_image | image_url: width: 1600 | image_tag:
        loading: 'lazy',
        widths: '600, 900, 1200, 1600',
        sizes: '(max-width: 900px) 100vw, 60vw',
        alt: visual_image.alt | default: collection.title,
        class: 'sf-collection-split__img'
      }}
    {%- else -%}
      <div class="sf-collection-split__fallback" aria-hidden="true">
        <span class="sf-collection-split__wire"></span>
        <span class="sf-collection-split__shade"></span>
        <span class="sf-collection-split__glow"></span>
      </div>
    {%- endif -%}

    {%- if section.settings.badge != blank -%}
      <span class="sf-collection-split__badge">
        <span class="sf-collection-split__badge-dot"></span>{{ section.settings.badge }}
      </span>
    {%- endif -%}
    <div class="sf-collection-split__index" aria-hidden="true">{{ section.settings.index_number }}</div>
  </a>
</section>

{% stylesheet %}
  .sf-collection-split {
    display: grid;
    grid-template-columns: minmax(360px, 5fr) minmax(0, 7fr);
    align-items: stretch;
    min-height: clamp(500px, 68vh, 680px);
    border-block: 1px solid var(--ed-line);
  }

  .sf-collection-split--reverse {
    grid-template-columns: 7fr 5fr;
  }

  .sf-collection-split--reverse .sf-collection-split__left {
    order: 2;
    border-right: none;
    border-left: 1px solid var(--ed-line);
  }

  .sf-collection-split--reverse .sf-collection-split__right {
    order: 1;
  }

  .sf-collection-split__left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 28px;
    padding: clamp(54px, 6vw, 72px) 56px;
    border-right: 1px solid var(--ed-line);
    background: var(--ed-bg);
  }

  .sf-collection-split__title {
    margin-top: 14px;
    font-size: clamp(46px, 5.8vw, 84px);
    line-height: 0.94;
    text-wrap: balance;
  }

  .sf-collection-split__quote {
    position: relative;
    max-width: 25em;
    margin: 0;
    padding-left: 22px;
    color: var(--ed-muted);
    font-family: var(--ed-font-display);
    font-size: clamp(18px, 1.45vw, 21px);
    font-style: italic;
    line-height: 1.42;
  }

  .sf-collection-split__quote::before {
    position: absolute;
    top: -12px;
    left: -10px;
    color: var(--ed-accent);
    content: "";
    font-size: 60px;
    font-style: italic;
    line-height: 1;
  }

  .sf-collection-split__cta {
    margin: 0;
  }

  .sf-collection-split__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 20px;
    border-top: 1px solid var(--ed-line);
    color: var(--ed-muted);
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .sf-collection-split__right {
    position: relative;
    display: block;
    overflow: hidden;
    background: linear-gradient(135deg, #2a2520 0%, #0c0a08 60%);
    color: #fff;
    text-decoration: none;
  }

  .sf-collection-split__right::after {
    position: absolute;
    top: 20%;
    left: 25%;
    z-index: 1;
    width: 60%;
    height: 60%;
    background: radial-gradient(ellipse at center, rgba(253, 198, 86, 0.45), transparent 60%);
    content: "";
    filter: blur(40px);
    animation: sf-collection-split-pulse 6s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes sf-collection-split-pulse {
    0%, 100% {
      opacity: 0.8;
      transform: scale(1);
    }

    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }

  html[data-ed-mode="day"] .sf-collection-split__right {
    background: linear-gradient(135deg, #ddd6c8, #b8b1a3);
  }

  .sf-collection-split__img {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center center;
    transition: transform 1.2s var(--ed-ease);
  }

  .sf-collection-split__right:hover .sf-collection-split__img {
    transform: scale(1.04);
  }

  .sf-collection-split__fallback {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(circle at 52% 48%, rgba(255, 225, 147, 0.82), transparent 24%),
      linear-gradient(135deg, #2a2520, #0c0a08 68%);
  }

  .sf-collection-split__wire {
    position: absolute;
    top: 0;
    left: 50%;
    width: 1px;
    height: 46%;
    transform: translateX(-50%);
    background: rgba(255, 250, 240, 0.42);
  }

  .sf-collection-split__shade {
    position: absolute;
    top: 40%;
    left: 50%;
    width: min(34%, 180px);
    min-width: 96px;
    aspect-ratio: 1.85;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 250, 240, 0.2);
    border-radius: 999px 999px 24px 24px;
    background: rgba(255, 250, 240, 0.12);
  }

  .sf-collection-split__glow {
    width: min(42%, 260px);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 225, 147, 0.92), rgba(255, 225, 147, 0.1) 60%, transparent 72%);
    filter: blur(2px);
  }

  .sf-collection-split__badge {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--ed-pill);
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  .sf-collection-split__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ed-accent);
    box-shadow: 0 0 8px var(--ed-accent);
  }

  .sf-collection-split__index {
    position: absolute;
    right: 32px;
    bottom: 24px;
    z-index: 3;
    color: rgba(255, 255, 255, 0.1);
    font-family: var(--ed-font-display);
    font-size: clamp(72px, 9vw, 140px);
    font-feature-settings: "tnum";
    font-style: italic;
    line-height: 0.8;
    pointer-events: none;
  }

  @media (max-width: 1100px) {
    .sf-collection-split,
    .sf-collection-split--reverse {
      grid-template-columns: 1fr;
    }

    .sf-collection-split__left,
    .sf-collection-split--reverse .sf-collection-split__left {
      order: 1;
      padding: 56px 24px;
      border-right: none;
      border-bottom: 1px solid var(--ed-line);
      border-left: none;
    }

    .sf-collection-split__right,
    .sf-collection-split--reverse .sf-collection-split__right {
      order: 2;
      min-height: clamp(360px, 54vh, 560px);
    }
  }

  @media (max-width: 640px) {
    .sf-collection-split__left {
      gap: 30px;
      padding: 56px 20px;
    }

    .sf-collection-split__title {
      font-size: clamp(44px, 15vw, 72px);
    }

    .sf-collection-split__quote {
      font-size: 19px;
    }

    .sf-collection-split__meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bento - Featured",
  "tag": "section",
  "class": "section-ed-bento",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "index_number", "label": "Index number", "default": "02" },
    { "type": "text", "id": "index_label", "label": "Index label", "default": "Featured" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Make your workspace <em>yours</em>.</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A good lamp should feel useful in the day and calm at night."
    },
    { "type": "text", "id": "view_all_label", "label": "CTA label", "default": "Shop now" },
    { "type": "url", "id": "view_all_link", "label": "CTA link" },
    { "type": "text", "id": "meta_left", "label": "Meta left", "default": "Warm room edits" },
    { "type": "text", "id": "meta_right", "label": "Meta right", "default": "Curated online" },
    { "type": "header", "content": "Visual" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "badge", "label": "Image badge", "default": "Featured" },
    { "type": "checkbox", "id": "reverse", "label": "Reverse (image on left)", "default": false }
  ],
  "presets": [
    { "name": "Bento - Featured" }
  ]
}
{% endschema %}
