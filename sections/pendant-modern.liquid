{%- liquid
  assign collection = collections[section.settings.collection]
  assign hero_image = section.settings.image | default: collection.image
  assign shop_url = section.settings.cta_link | default: collection.url | default: routes.all_products_collection_url
-%}

<section class="sf-pendant-modern ed-section" id="sf-pendant-modern-{{ section.id }}">
  <div class="sf-pendant-modern__inner">
    <div class="sf-pendant-modern__copy ed-reveal ed-reveal--lr">
      <div>
        <div class="ed-eyebrow">{{ section.settings.index_number }} / {{ section.settings.index_label }}</div>
        <h2 class="ed-display sf-pendant-modern__title">{{ section.settings.heading }}</h2>
      </div>

      {%- if section.settings.description != blank -%}
        <p class="sf-pendant-modern__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="sf-pendant-modern__actions">
        {%- if section.settings.cta_label != blank -%}
          <a class="ed-btn ed-btn--solid" href="{{ shop_url }}">
            {{ section.settings.cta_label }}
            <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
          </a>
        {%- endif -%}
        <div class="sf-pendant-modern__meta">
          <span>{{ section.settings.meta_left }}</span>
          <span>{{ section.settings.meta_right }}</span>
        </div>
      </div>
    </div>

    <a class="sf-pendant-modern__stage ed-reveal" href="{{ shop_url }}" aria-label="{{ section.settings.cta_label | default: collection.title | escape }}">
      {%- if hero_image != blank -%}
        {{ hero_image | image_url: width: 1800 | image_tag:
          loading: 'lazy',
          widths: '700, 1000, 1400, 1800',
          sizes: '(max-width: 1100px) 100vw, 58vw',
          alt: hero_image.alt | default: collection.title,
          class: 'sf-pendant-modern__hero'
        }}
      {%- else -%}
        <div class="sf-pendant-modern__fallback" aria-hidden="true">
          <span class="sf-pendant-modern__wire"></span>
          <span class="sf-pendant-modern__shade"></span>
          <span class="sf-pendant-modern__glow"></span>
        </div>
      {%- endif -%}

      {%- if section.settings.badge != blank -%}
        <span class="sf-pendant-modern__badge">
          <span class="sf-pendant-modern__badge-dot"></span>{{ section.settings.badge }}
        </span>
      {%- endif -%}
      <span class="sf-pendant-modern__index" aria-hidden="true">{{ section.settings.index_number }}</span>
    </a>
  </div>
</section>

{% stylesheet %}
  .sf-pendant-modern {
    padding: 0;
    overflow: hidden;
    border-block: 1px solid var(--ed-line);
    background: var(--ed-bg);
  }

  .sf-pendant-modern__inner {
    display: grid;
    width: 100%;
    min-height: clamp(540px, 72vh, 720px);
    grid-template-columns: 5fr 7fr;
    align-items: stretch;
  }

  .sf-pendant-modern__copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: space-between;
    gap: 30px;
    padding: clamp(58px, 6vw, 76px) 56px;
    border-right: 1px solid rgba(255, 250, 240, 0.12);
    background:
      radial-gradient(circle at 12% 12%, rgba(253, 198, 86, 0.12), transparent 34%),
      linear-gradient(145deg, #14120f 0%, #090807 100%);
    color: #fffaf0;
  }

  .sf-pendant-modern__copy .ed-eyebrow {
    border-color: rgba(255, 250, 240, 0.14);
    background: rgba(255, 250, 240, 0.06);
    color: rgba(255, 250, 240, 0.66);
  }

  .sf-pendant-modern__title {
    max-width: 9ch;
    margin-top: 18px;
    color: #fffaf0;
    font-size: clamp(48px, 6.4vw, 92px);
    line-height: 0.94;
    text-wrap: balance;
  }

  .sf-pendant-modern__desc {
    max-width: 25em;
    margin: 0;
    color: rgba(255, 250, 240, 0.74);
    font-family: var(--ed-font-display);
    font-size: clamp(18px, 1.45vw, 21px);
    font-style: italic;
    line-height: 1.42;
  }

  .sf-pendant-modern__actions {
    display: grid;
    gap: 24px;
  }

  .sf-pendant-modern__meta {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 250, 240, 0.14);
    color: rgba(255, 250, 240, 0.56);
    font-family: var(--ed-font-body);
    font-size: 11px;
    font-weight: 780;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .sf-pendant-modern__stage {
    position: relative;
    display: block;
    min-width: 0;
    overflow: hidden;
    background: linear-gradient(135deg, #2a2520 0%, #0c0a08 60%);
    color: #fffaf0;
    isolation: isolate;
  }

  .sf-pendant-modern__stage::before {
    position: absolute;
    top: 18%;
    left: 22%;
    z-index: 1;
    width: 58%;
    height: 62%;
    content: "";
    background: radial-gradient(ellipse at center, rgba(253, 198, 86, 0.36), transparent 62%);
    filter: blur(42px);
    pointer-events: none;
  }

  .sf-pendant-modern__stage::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    content: "";
    background:
      linear-gradient(180deg, rgba(12, 10, 8, 0.02), rgba(12, 10, 8, 0.14) 56%, rgba(12, 10, 8, 0.56)),
      linear-gradient(90deg, rgba(12, 10, 8, 0.24), transparent 46%);
    pointer-events: none;
  }

  .sf-pendant-modern__hero {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center center;
    transition: transform 1.2s var(--ed-ease), filter 0.5s var(--ed-ease);
  }

  .sf-pendant-modern__stage:hover .sf-pendant-modern__hero {
    transform: scale(1.04);
    filter: saturate(1.04);
  }

  .sf-pendant-modern__badge {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border: 1px solid rgba(255, 250, 240, 0.15);
    border-radius: var(--ed-pill);
    background: rgba(0, 0, 0, 0.45);
    color: rgba(255, 250, 240, 0.86);
    font-family: var(--ed-font-body);
    font-size: 11px;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  .sf-pendant-modern__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ed-accent);
    box-shadow: 0 0 8px var(--ed-accent);
  }

  .sf-pendant-modern__index {
    position: absolute;
    right: 32px;
    bottom: 24px;
    z-index: 3;
    color: rgba(255, 250, 240, 0.12);
    font-family: var(--ed-font-display);
    font-size: clamp(72px, 9vw, 140px);
    font-style: italic;
    line-height: 0.8;
    pointer-events: none;
  }

  .sf-pendant-modern__fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 52% 48%, rgba(255, 225, 147, 0.78), transparent 25%),
      linear-gradient(135deg, #24201a, #090807);
  }

  .sf-pendant-modern__wire {
    position: absolute;
    top: 0;
    left: 50%;
    width: 1px;
    height: 45%;
    transform: translateX(-50%);
    background: rgba(255, 250, 240, 0.4);
  }

  .sf-pendant-modern__shade {
    position: absolute;
    top: 39%;
    left: 50%;
    width: min(34%, 170px);
    min-width: 92px;
    aspect-ratio: 1.85;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 250, 240, 0.18);
    border-radius: 999px 999px 22px 22px;
    background: rgba(255, 250, 240, 0.12);
  }

  .sf-pendant-modern__glow {
    width: min(44%, 250px);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 225, 147, 0.95), rgba(255, 225, 147, 0.1) 60%, transparent 72%);
    filter: blur(2px);
  }

  @media (max-width: 1100px) {
    .sf-pendant-modern__inner {
      grid-template-columns: 1fr;
    }

    .sf-pendant-modern__copy {
      order: 1;
      padding: 56px 24px;
      border-right: none;
      border-bottom: 1px solid rgba(255, 250, 240, 0.12);
    }

    .sf-pendant-modern__stage {
      order: 2;
      min-height: clamp(360px, 54vh, 560px);
    }
  }

  @media (max-width: 720px) {
    .sf-pendant-modern__title {
      font-size: clamp(44px, 16vw, 70px);
    }

    .sf-pendant-modern__meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pendant modern feature",
  "tag": "section",
  "class": "section-sf-pendant-modern",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "index_number", "label": "Index number", "default": "03" },
    { "type": "text", "id": "index_label", "label": "Index label", "default": "Pendant lamps" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Pendant lamps</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Sculptural ceiling lights for dining tables, entries, and quiet corners that need a warmer focal point."
    },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop pendants" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "text", "id": "meta_left", "label": "Meta left", "default": "Warm room edits" },
    { "type": "text", "id": "meta_right", "label": "Meta right", "default": "Curated online" },
    { "type": "header", "content": "Source" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "header", "content": "Visual" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "badge", "label": "Badge", "default": "Pendant edit" }
  ],
  "presets": [
    { "name": "Pendant modern feature" }
  ]
}
{% endschema %}
