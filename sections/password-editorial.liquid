<section class="ed-password ed-section">
  <div class="ed-password__inner ed-reveal-stagger">
    <a class="ed-password__logo" href="{{ routes.root_url }}">
      {%- if settings.logo != blank -%}
        {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
        {{ settings.logo | image_url: width: 320 | image_tag: loading: 'eager', alt: logo_alt, class: 'ed-password__logo-img' }}
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <div class="ed-eyebrow">{{ section.settings.eyebrow }}</div>
    <h1 class="ed-display ed-password__title">{{ section.settings.heading }}</h1>

    {%- if shop.password_message != blank -%}
      <div class="ed-password__message">{{ shop.password_message }}</div>
    {%- elsif section.settings.description != blank -%}
      <p class="ed-password__message">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'ed-password__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="visually-hidden" for="ed-password-email-{{ section.id }}">Email</label>
      <input
        id="ed-password-email-{{ section.id }}"
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.email_placeholder }}"
        autocomplete="email"
        required
      >
      <button type="submit">
        {{ section.settings.submit_label }} <span aria-hidden="true">-&gt;</span>
      </button>

      {%- if form.posted_successfully? -%}
        <p class="ed-password__form-message" role="status">Thanks. You are on the list.</p>
      {%- elsif form.errors -%}
        <div class="ed-password__form-message ed-password__form-message--error">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}
    {%- endform -%}

    <button type="button" class="ed-password__enter" on:click="#password-form/showDialog">
      {{ section.settings.password_label }}
    </button>
  </div>
</section>

{% stylesheet %}
  .ed-password-layout {
    background: var(--ed-bg);
    color: var(--ed-fg);
  }

  .ed-password-layout .password-main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .ed-password {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 64px 24px;
    position: relative;
    overflow: hidden;
  }

  .ed-password__inner {
    position: relative;
    z-index: 1;
    width: min(720px, 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    text-align: center;
  }

  .ed-password__logo {
    color: var(--ed-fg);
    text-decoration: none;
    font-family: var(--ed-font-body);
    font-style: normal;
    font-weight: 850;
    font-size: 32px;
    letter-spacing: 0;
    margin-bottom: 12px;
  }

  .ed-password__logo-img {
    max-width: 180px;
    height: auto;
    display: block;
  }

  .ed-password__title {
    font-family: var(--ed-font-body);
    font-weight: 900;
    font-size: clamp(56px, 9vw, 126px);
    line-height: 0.92;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .ed-password__title em {
    font-family: var(--ed-font-display);
    font-weight: 400;
  }

  .ed-password__message {
    font-family: var(--ed-font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ed-muted);
    max-width: 34em;
    margin: 0;
  }

  .ed-password__message p {
    margin: 0;
  }

  .ed-password__form {
    width: min(520px, 100%);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    margin-top: 18px;
    padding: 6px;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-pill);
    background: color-mix(in srgb, var(--ed-card) 92%, transparent);
  }

  .ed-password__form input {
    width: 100%;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    color: var(--ed-fg);
    padding: 13px 14px;
    font-family: var(--ed-font-body);
    font-size: 16px;
  }

  .ed-password__form input::placeholder {
    color: var(--ed-muted);
  }

  .ed-password__form button {
    border: none;
    border-radius: var(--ed-pill);
    background: var(--ed-fg);
    color: var(--ed-bg);
    padding: 12px 18px;
    font-family: var(--ed-font-body);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
  }

  .ed-password__form button:hover {
    background: var(--ed-accent);
    color: #0a0a0a;
  }

  .ed-password__form-message {
    grid-column: 1 / -1;
    margin: 4px 12px 8px;
    color: var(--ed-muted);
    font-family: var(--ed-font-body);
    font-size: 12px;
  }

  .ed-password__form-message--error {
    color: #ff9b9b;
  }

  .ed-password__enter {
    border: 0;
    background: transparent;
    color: var(--ed-muted);
    padding: 8px;
    margin-top: 4px;
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
    cursor: pointer;
  }

  .ed-password__enter:hover {
    color: var(--ed-fg);
  }

  .ed-password-layout .password-enter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 24px;
    background: var(--ed-bg);
    color: var(--ed-muted);
    border-top: 1px solid var(--ed-line);
    font-family: var(--ed-font-body);
    font-size: 12px;
  }

  .ed-password-layout .password-enter__powered-by,
  .ed-password-layout .password-enter__admin-link {
    margin: 0;
  }

  .ed-password-layout .password-enter__powered-by {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .ed-password-layout .password-enter__powered-by svg {
    height: 16px;
    color: var(--ed-fg);
  }

  .ed-password-layout .password-enter__links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .ed-password-layout .password-enter a,
  .ed-password-layout .password-enter__button {
    color: var(--ed-fg);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .ed-password-layout .password-enter__button {
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
    font: inherit;
  }

  .ed-password-layout .password-dialog {
    width: min(520px, calc(100vw - 32px));
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-radius-card);
    background: var(--ed-bg);
    color: var(--ed-fg);
    padding: 0;
    box-shadow: var(--ed-shadow-card);
    overflow: hidden;
  }

  .ed-password-layout .password-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
  }

  .ed-password-layout .password-dialog__header {
    display: flex;
    justify-content: flex-end;
    padding: 16px 16px 0;
  }

  .ed-password-layout .password-dialog__close-button {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ed-line);
    border-radius: 50%;
    background: transparent;
    color: var(--ed-fg);
    cursor: pointer;
  }

  .ed-password-layout .password-dialog__content {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 18px;
    padding: 24px 28px 32px;
  }

  .ed-password-layout .password-dialog__title {
    font-family: var(--ed-font-display);
    font-weight: 400;
    font-size: 34px;
    margin: 0;
  }

  .ed-password-layout .email-signup__input-group {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
  }

  .ed-password-layout .field__input {
    min-width: 0;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-radius);
    background: transparent;
    color: var(--ed-fg);
    padding: 13px 14px;
    font: inherit;
  }

  .ed-password-layout .password-dialog__submit-button {
    border: 0;
    border-radius: var(--ed-radius);
    background: var(--ed-fg);
    color: var(--ed-bg);
    padding: 13px 18px;
    font-family: var(--ed-font-body);
    cursor: pointer;
    min-height: 46px;
  }

  .ed-password-layout .email-signup__message--error {
    color: #ff9b9b;
    font-family: var(--ed-font-body);
    font-size: 13px;
  }

  @media (max-width: 640px) {
    .ed-password {
      padding: 48px 14px;
    }

    .ed-password__inner {
      gap: 14px;
    }

    .ed-password__logo {
      max-width: 100%;
      font-size: 24px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .ed-password__title {
      font-size: 46px;
      line-height: 0.98;
    }

    .ed-password__form {
      grid-template-columns: 1fr;
      border-radius: var(--ed-radius-card);
      padding: 10px;
    }

    .ed-password__form button {
      width: 100%;
    }

    .ed-password-layout .email-signup__input-group {
      grid-template-columns: 1fr;
    }

    .ed-password-layout .password-dialog__content {
      padding: 18px 18px 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Password - Editorial",
  "tag": "section",
  "class": "section-ed-password",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Opening soon" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Light is <em>coming</em>.</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback message",
      "default": "The studio is preparing its next release. Join the list for first access."
    },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "your@email.com" },
    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Notify me" },
    { "type": "text", "id": "password_label", "label": "Password button label", "default": "Enter with password" }
  ],
  "presets": [
    { "name": "Password - Editorial" }
  ],
  "enabled_on": {
    "templates": ["password"]
  }
}
{% endschema %}
