{%- liquid
  assign p = product
  if p == empty or p == null
    assign p = all_products | first
  endif
  assign current_variant = p.selected_or_first_available_variant
  assign featured_media = current_variant.featured_media | default: p.featured_media
-%}

<section class="ed-product ed-section">
  <div class="ed-product__index">
    <span>{{ section.settings.index_number | default: '01' }}</span>
    <hr>
    <span>{{ p.type | default: section.settings.index_label }}</span>
  </div>

  <div class="ed-product__gallery ed-reveal">
    {%- if p.media.size > 0 -%}
      <div class="ed-product__gallery-main">
        {%- if featured_media.media_type == 'image' -%}
          {{ featured_media | image_url: width: 1600 | image_tag:
            class: 'ed-product__media-main',
            loading: 'eager',
            widths: '600, 900, 1200, 1600',
            sizes: '(max-width: 900px) 100vw, 60vw',
            alt: featured_media.alt | default: p.title
          }}
        {%- else -%}
          {{ featured_media | media_tag: class: 'ed-product__media-main', autoplay: true, loop: true, muted: true, controls: true }}
        {%- endif -%}
      </div>
      <div class="ed-product__media-templates" hidden>
        {%- for m in p.media -%}
          <template data-ed-media-template="{{ m.id }}">
            {%- if m.media_type == 'image' -%}
              {{ m | image_url: width: 1600 | image_tag:
                class: 'ed-product__media-main',
                loading: 'eager',
                widths: '600, 900, 1200, 1600',
                sizes: '(max-width: 900px) 100vw, 60vw',
                alt: m.alt | default: p.title
              }}
            {%- else -%}
              {{ m | media_tag: class: 'ed-product__media-main', autoplay: true, loop: true, muted: true, controls: true }}
            {%- endif -%}
          </template>
        {%- endfor -%}
      </div>
      {%- if p.media.size > 1 -%}
        <div class="ed-product__thumbs" aria-label="Product media">
          {%- for m in p.media -%}
            <button
              type="button"
              class="ed-product__thumb {% if m.id == featured_media.id %}is-active{% endif %}"
              data-ed-thumb
              data-ed-media-id="{{ m.id }}"
              data-ed-main-src="{{ m.preview_image | image_url: width: 1600 }}"
              data-ed-main-alt="{{ m.alt | default: p.title | escape }}"
              aria-label="View media {{ forloop.index }}"
              {% if m.id == featured_media.id %}aria-current="true"{% endif %}
            >
              {{ m.preview_image | image_url: width: 240 | image_tag:
                loading: 'lazy',
                class: 'ed-product__thumb-img',
                alt: m.alt | default: p.title
              }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- elsif p.featured_image -%}
      <div class="ed-product__gallery-main">
        {{ p.featured_image | image_url: width: 1600 | image_tag:
            class: 'ed-product__media-main',
            loading: 'eager',
            widths: '600, 900, 1200, 1600',
            sizes: '(max-width: 900px) 100vw, 60vw',
            alt: p.featured_image.alt | default: p.title
          }}
      </div>
    {%- else -%}
      <div class="ed-product__placeholder">No image</div>
    {%- endif -%}
  </div>

  <div class="ed-product__details ed-reveal-stagger">
    <div class="ed-product__vendor">{{ p.vendor | default: section.settings.brand | default: shop.name }}</div>
    <h1 class="ed-display ed-product__title">{{ p.title }}</h1>

    <div class="ed-product__price-row">
      <div class="ed-product__price">{{ current_variant.price | money }}</div>
      <div class="ed-product__price-compare">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          {{ current_variant.compare_at_price | money }}
        {%- endif -%}
      </div>
      <span class="ed-product__sale" {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>Sale</span>
    </div>

    <form
      action="{{ routes.cart_add_url }}"
      method="post"
      enctype="multipart/form-data"
      class="ed-product__form"
      data-ed-product-form
    >
      <input type="hidden" name="id" value="{{ current_variant.id }}" data-ed-variant-id>

      {%- unless p.has_only_default_variant -%}
        <div class="ed-product__variants">
          {%- for option in p.options_with_values -%}
            <fieldset class="ed-product__variant-group">
              <legend>{{ option.name }}</legend>
              <div class="ed-product__variant-options">
                {%- for value in option.values -%}
                  <label class="ed-product__variant {% if value == option.selected_value %}is-selected{% endif %}">
                    <input
                      type="radio"
                      name="options[{{ option.name | escape }}]"
                      value="{{ value | escape }}"
                      {% if value == option.selected_value %}checked{% endif %}
                    >
                    <span>{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <div class="ed-product__quantity">
        <label for="ed-qty-{{ section.id }}">Quantity</label>
        <div class="ed-product__qty-control">
          <button type="button" data-ed-qty-step="-1" aria-label="Decrease quantity for {{ p.title | escape }}">-</button>
          <input id="ed-qty-{{ section.id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric" aria-label="Quantity for {{ p.title | escape }}">
          <button type="button" data-ed-qty-step="1" aria-label="Increase quantity for {{ p.title | escape }}">+</button>
        </div>
      </div>

      <button type="submit" class="ed-btn ed-btn--solid ed-product__add" data-ed-add-button {% unless current_variant.available %}disabled{% endunless %}>
        <span data-ed-add-label>
          {%- if current_variant.available -%}
            Add to cart - {{ current_variant.price | money }}
          {%- else -%}
            Sold out
          {%- endif -%}
        </span>
        <span class="ed-btn__arrow" aria-hidden="true">-&gt;</span>
      </button>
    </form>

    <ul class="ed-product__values">
      <li><span class="ed-product__value-num">01</span><span>Carefully packed</span></li>
      <li><span class="ed-product__value-num">02</span><span>Secure checkout</span></li>
      <li><span class="ed-product__value-num">03</span><span>Easy returns</span></li>
      <li><span class="ed-product__value-num">04</span><span>Support included</span></li>
    </ul>

    <details class="ed-product__accordion" open>
      <summary aria-expanded="true">Description</summary>
      <div class="ed-product__accordion-content ed-product__rte">
        {%- if p.description != blank -%}
          {{ p.description }}
        {%- else -%}
          <p>Product details are being updated. Review the photos and selected variant before checkout.</p>
        {%- endif -%}
      </div>
    </details>
    <details class="ed-product__accordion">
      <summary aria-expanded="false">Shipping &amp; Returns</summary>
      <div class="ed-product__accordion-content ed-product__rte">
        <p>Shipping, taxes, and available delivery options are calculated at checkout. For returns, use the policy links in the footer or contact support before sending an item back.</p>
      </div>
    </details>
    <details class="ed-product__accordion">
      <summary aria-expanded="false">Care</summary>
      <div class="ed-product__accordion-content ed-product__rte">
        <p>Wipe gently with a soft, dry cloth. Avoid harsh cleaners, moisture, and long exposure to direct sunlight unless the product page says otherwise.</p>
      </div>
    </details>
  </div>
</section>

{% stylesheet %}
  .ed-product {
    position: relative;
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 56px;
    padding: 80px 32px;
    align-items: start;
  }
  .ed-product__index {
    position: absolute;
    top: 96px;
    left: 32px;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ed-muted);
    z-index: 2;
  }
  .ed-product__index span:first-child {
    color: var(--ed-fg);
    padding: 4px 10px;
    border: 1px solid var(--ed-line-strong);
    border-radius: var(--ed-pill);
  }
  .ed-product__index hr {
    width: 40px;
    height: 1px;
    background: var(--ed-line);
    border: none;
    margin: 0;
  }

  .ed-product__gallery {
    position: relative;
    top: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ed-product__gallery-main {
    border-radius: var(--ed-radius-card);
    overflow: hidden;
    aspect-ratio: 1;
    background: var(--ed-card);
    border: 1px solid var(--ed-line);
    position: relative;
  }
  .ed-product__media-main {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ed-product__thumbs {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }
  .ed-product__thumb {
    aspect-ratio: 1;
    border-radius: var(--ed-radius);
    overflow: hidden;
    border: 1px solid var(--ed-line);
    background: var(--ed-card);
    cursor: pointer;
    padding: 0;
    transition: border-color 0.25s var(--ed-ease);
  }
  .ed-product__thumb.is-active { border-color: var(--ed-fg); }
  .ed-product__thumb:hover { border-color: var(--ed-line-strong); }
  .ed-product__thumb-img { width: 100%; height: 100%; object-fit: cover; }
  .ed-product__placeholder {
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    color: var(--ed-muted);
    border: 1px dashed var(--ed-line);
    border-radius: var(--ed-radius-card);
  }

  .ed-product__details {
    padding-top: 64px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .ed-product__vendor {
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }
  .ed-product__title {
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1.02;
    letter-spacing: 0;
    text-wrap: balance;
  }
  .ed-product__price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 12px 0 6px;
  }
  .ed-product__price {
    font-family: var(--ed-font-display);
    font-style: italic;
    font-size: 32px;
    color: var(--ed-fg);
    letter-spacing: 0;
  }
  .ed-product__price-compare {
    font-family: var(--ed-font-body);
    font-size: 14px;
    color: var(--ed-muted);
    text-decoration: line-through;
  }
  .ed-product__sale {
    font-family: var(--ed-font-body);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ed-accent);
    padding: 4px 10px;
    border: 1px solid var(--ed-accent);
    border-radius: var(--ed-pill);
  }
  /* Form */
  .ed-product__form {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: 14px;
  }
  .ed-product__variants {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .ed-product__variant-group {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ed-product__variant-group legend {
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }
  .ed-product__variant-options { display: flex; gap: 8px; flex-wrap: wrap; }
  .ed-product__variant {
    position: relative;
    padding: 10px 18px;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-pill);
    font-family: var(--ed-font-body);
    font-size: 13px;
    color: var(--ed-fg);
    cursor: pointer;
    transition: border-color 0.25s var(--ed-ease), background 0.25s var(--ed-ease);
  }
  .ed-product__variant:hover { border-color: var(--ed-line-strong); }
  .ed-product__variant.is-selected,
  .ed-product__variant:has(input:checked) {
    background: var(--ed-fg);
    color: var(--ed-bg);
    border-color: var(--ed-fg);
  }
  .ed-product__variant input { position: absolute; opacity: 0; pointer-events: none; }

  .ed-product__quantity {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }
  .ed-product__quantity label {
    font-family: var(--ed-font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ed-muted);
  }
  .ed-product__qty-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--ed-line);
    border-radius: var(--ed-pill);
    padding: 4px;
  }
  .ed-product__qty-control button {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: transparent;
    color: var(--ed-fg);
    border: none;
    cursor: pointer;
    font-size: 16px;
    transition: background 0.2s var(--ed-ease);
  }
  .ed-product__qty-control button:hover { background: color-mix(in srgb, var(--ed-fg) 10%, transparent); }
  .ed-product__qty-control input {
    width: 40px;
    text-align: center;
    background: transparent;
    border: none;
    color: var(--ed-fg);
    font: inherit;
    appearance: textfield;
    -moz-appearance: textfield;
  }
  .ed-product__qty-control input::-webkit-outer-spin-button,
  .ed-product__qty-control input::-webkit-inner-spin-button {
    -webkit-appearance: none; margin: 0;
  }

  .ed-product__add {
    width: 100%;
    justify-content: space-between;
    padding: 18px 26px;
    margin-top: 4px;
  }
  .ed-product__add[disabled] { opacity: 0.4; cursor: not-allowed; }

  /* Value props */
  .ed-product__values {
    list-style: none;
    padding: 18px 0;
    margin: 4px 0 0;
    border-top: 1px solid var(--ed-line);
    border-bottom: 1px solid var(--ed-line);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px 18px;
  }
  .ed-product__values li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--ed-font-body);
    font-size: 13px;
    color: var(--ed-fg);
  }
  .ed-product__value-num {
    font-family: var(--ed-font-display);
    font-style: italic;
    color: var(--ed-accent);
    font-size: 16px;
    min-width: 22px;
  }

  /* Accordion */
  .ed-product__accordion {
    border-bottom: 1px solid var(--ed-line);
    padding: 18px 0;
  }
  .ed-product__accordion summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--ed-font-display);
    font-size: 22px;
    color: var(--ed-fg);
    letter-spacing: 0;
  }
  .ed-product__accordion summary::after {
    content: "+";
    font-family: var(--ed-font-body);
    font-size: 24px;
    color: var(--ed-muted);
    transition: transform 0.25s var(--ed-ease);
  }
  .ed-product__accordion[open] summary::after {
    content: "-";
  }
  .ed-product__accordion summary::-webkit-details-marker { display: none; }
  .ed-product__accordion[open] .ed-product__accordion-content {
    margin-top: 12px;
  }
  .ed-product__rte {
    font-family: var(--ed-font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--ed-muted);
    overflow-wrap: anywhere;
  }
  .ed-product__rte p {
    margin: 0 0 10px;
  }
  .ed-product__rte p:last-child { margin-bottom: 0; }
  .ed-product__rte ul,
  .ed-product__rte ol {
    margin: 0 0 12px;
    padding-left: 20px;
  }
  .ed-product__rte li { margin-bottom: 6px; }
  .ed-product__rte a {
    color: var(--ed-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .ed-product__rte img,
  .ed-product__rte video,
  .ed-product__rte iframe {
    max-width: 100%;
    height: auto;
    border-radius: var(--ed-radius);
  }
  .ed-product__rte table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
  }

  @media (max-width: 1100px) {
    .ed-product { grid-template-columns: 1fr; gap: 32px; padding: 72px 20px 64px; }
    .ed-product__index { position: static; margin-bottom: 16px; }
    .ed-product__gallery { position: relative; top: 0; }
    .ed-product__details { padding-top: 0; }
    .ed-product__title { font-size: clamp(32px, 8vw, 48px); }
  }
{% endstylesheet %}

<script>
  (function () {
    var productData = {
      variants: {{ p.variants | json }},
      currency: {{ cart.currency.iso_code | json }}
    };

    function money(cents) {
      try {
        return new Intl.NumberFormat(document.documentElement.lang || undefined, {
          style: 'currency',
          currency: productData.currency
        }).format((cents || 0) / 100);
      } catch (e) {
        return ((cents || 0) / 100).toFixed(2);
      }
    }

    function findSelectedVariant(form) {
      var selected = [];
      form.querySelectorAll('.ed-product__variant-group').forEach(function (group) {
        var checked = group.querySelector('input[type="radio"]:checked');
        selected.push(checked ? checked.value : '');
      });
      return productData.variants.find(function (variant) {
        return variant.options.every(function (option, index) {
          return option === selected[index];
        });
      });
    }

    function updateVariant(form) {
      var variant = findSelectedVariant(form);
      if (!variant) return;

      var idInput = form.querySelector('[data-ed-variant-id]');
      var productSection = form.closest('.ed-product');
      var price = productSection && productSection.querySelector('.ed-product__price');
      var compare = productSection && productSection.querySelector('.ed-product__price-compare');
      var sale = productSection && productSection.querySelector('.ed-product__sale');
      var add = form.querySelector('[data-ed-add-button]');
      var addLabel = add && add.querySelector('[data-ed-add-label]');

      if (idInput) idInput.value = variant.id;
      if (price) price.textContent = money(variant.price);
      if (compare) {
        compare.textContent = variant.compare_at_price && variant.compare_at_price > variant.price ? money(variant.compare_at_price) : '';
      }
      if (sale) {
        sale.hidden = !(variant.compare_at_price && variant.compare_at_price > variant.price);
      }
      if (add) {
        add.disabled = !variant.available;
      }
      if (addLabel) {
        addLabel.textContent = variant.available ? 'Add to cart - ' + money(variant.price) : 'Sold out';
      }
      if (productSection && variant.featured_media && variant.featured_media.id) {
        setActiveMedia(productSection, variant.featured_media.id);
      }
    }

    function mediaTemplate(section, mediaId) {
      if (!section || !mediaId) return null;
      var templates = section.querySelectorAll('[data-ed-media-template]');
      for (var i = 0; i < templates.length; i++) {
        if (templates[i].dataset.edMediaTemplate === String(mediaId)) return templates[i];
      }
      return null;
    }

    function setMainMedia(section, mediaId) {
      var wrap = section.querySelector('.ed-product__gallery-main');
      var template = mediaTemplate(section, mediaId);
      if (!wrap || !template) return false;
      if (template.content && template.content.childNodes.length) {
        wrap.replaceChildren(template.content.cloneNode(true));
      } else {
        wrap.innerHTML = template.innerHTML;
      }
      return true;
    }

    function setFallbackImage(section, thumb) {
      var wrap = section.querySelector('.ed-product__gallery-main');
      var src = thumb && (thumb.dataset.edMainSrc || thumb.querySelector('img')?.currentSrc || thumb.querySelector('img')?.src);
      if (!wrap || !src) return false;
      wrap.innerHTML = '';
      var img = document.createElement('img');
      img.className = 'ed-product__media-main';
      img.loading = 'eager';
      img.src = src;
      img.alt = thumb.dataset.edMainAlt || '';
      wrap.appendChild(img);
      return true;
    }

    function setActiveMedia(section, mediaId) {
      var thumb = section.querySelector('[data-ed-media-id="' + mediaId + '"]');
      if (!thumb) return;
      if (!setMainMedia(section, mediaId) && !setFallbackImage(section, thumb)) return;
      section.querySelectorAll('[data-ed-thumb]').forEach(function (b) {
        var isActive = b === thumb;
        b.classList.toggle('is-active', isActive);
        if (isActive) {
          b.setAttribute('aria-current', 'true');
        } else {
          b.removeAttribute('aria-current');
        }
      });
    }

    document.addEventListener('change', function (e) {
      var input = e.target.closest('.ed-product__variant input[type="radio"]');
      if (!input) return;
      var form = input.closest('[data-ed-product-form]');
      if (!form) return;
      form.querySelectorAll('.ed-product__variant').forEach(function (label) {
        var checked = label.querySelector('input[type="radio"]:checked');
        label.classList.toggle('is-selected', Boolean(checked));
      });
      updateVariant(form);
    });

    // Thumb click -> swap main image
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-ed-thumb]');
      if (!btn) return;
      var section = btn.closest('.ed-product');
      if (!section) return;
      e.preventDefault();
      setActiveMedia(section, btn.dataset.edMediaId);
    });

    document.addEventListener('toggle', function (e) {
      var details = e.target.closest && e.target.closest('.ed-product__accordion');
      if (!details) return;
      var summary = details.querySelector('summary');
      if (summary) summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
    }, true);

    // Quantity stepper
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-ed-qty-step]');
      if (!btn) return;
      var wrap = btn.closest('.ed-product__qty-control');
      var input = wrap && wrap.querySelector('input');
      if (!input) return;
      var step = parseInt(btn.dataset.edQtyStep, 10) || 1;
      var next = Math.max(1, (parseInt(input.value, 10) || 1) + step);
      input.value = next;
    });
  })();
</script>

{% schema %}
{
  "name": "Product - Editorial",
  "tag": "section",
  "class": "section-ed-product",
  "settings": [
    { "type": "text", "id": "index_number", "label": "Index number", "default": "01" },
    { "type": "text", "id": "index_label", "label": "Index label", "default": "Product" },
    { "type": "text", "id": "brand", "label": "Brand text (when product has no vendor)" }
  ],
  "presets": [
    { "name": "Product - Editorial" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
