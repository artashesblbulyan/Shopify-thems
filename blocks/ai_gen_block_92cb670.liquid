{% doc %}
  @prompt
    Create a fixed bottom navigation bar that automatically hides when scrolling down and reappears when scrolling up. Include smooth slide animations, customizable navigation links, icons, background color, text color, and the ability to add call-to-action buttons. The bar should be mobile-friendly and stay fixed at the bottom of the viewport.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bottom-nav-{{ ai_gen_id }} {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    z-index: 1000;
    transform: translateY(0);
    transition: transform 0.3s ease-in-out;
    box-shadow: 0 -2px 10px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    display: block;
  }

  .ai-bottom-nav-{{ ai_gen_id }}.ai-bottom-nav-hidden-{{ ai_gen_id }} {
    transform: translateY(100%);
  }

  .ai-bottom-nav-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    gap: 16px;
  }

  .ai-bottom-nav-links-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.link_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-bottom-nav-link-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    transition: color 0.2s ease;
  }

  .ai-bottom-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
  }

  .ai-bottom-nav-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
  }

  .ai-bottom-nav-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  .ai-bottom-nav-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background_color }};
    color: {{ block.settings.cta_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-bottom-nav-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-bottom-nav-links-{{ ai_gen_id }} {
      gap: {{ block.settings.link_spacing | times: 0.7 }}px;
    }

    .ai-bottom-nav-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-bottom-nav-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }

    .ai-bottom-nav-cta-{{ ai_gen_id }} {
      padding: {{ block.settings.cta_padding_vertical | times: 0.8 }}px {{ block.settings.cta_padding_horizontal | times: 0.8 }}px;
      font-size: {{ block.settings.cta_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

