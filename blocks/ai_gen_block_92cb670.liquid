<script>
  (function() {
    class BottomNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.lastScrollY = window.scrollY;
        this.scrollThreshold = {{ block.settings.scroll_threshold }};
        this.isHidden = false;
      }

      connectedCallback() {
        this.handleScroll = this.handleScroll.bind(this);
        window.addEventListener('scroll', this.handleScroll, { passive: true });
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }

      handleScroll() {
        const currentScrollY = window.scrollY;
        const scrollDifference = currentScrollY - this.lastScrollY;

        if (Math.abs(scrollDifference) < this.scrollThreshold) {
          return;
        }

        if (scrollDifference > 0 && currentScrollY > 100) {
          if (!this.isHidden) {
            this.classList.add('ai-bottom-nav-hidden-{{ ai_gen_id }}');
            this.isHidden = true;
          }
        } else if (scrollDifference < 0) {
          if (this.isHidden) {
            this.classList.remove('ai-bottom-nav-hidden-{{ ai_gen_id }}');
            this.isHidden = false;
          }
        }

        this.lastScrollY = currentScrollY;
      }
    }

    customElements.define('bottom-nav-{{ ai_gen_id }}', BottomNav{{ ai_gen_id }});
  })();
</script>

