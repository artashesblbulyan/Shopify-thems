{% doc %}
  @prompt
    Create a bottom sticky section for my website that appears **only when the user scrolls to the very bottom of the page**.
    
    Requirements:
    
    * Show the section only at the bottom of the page, hidden otherwise.
    * Add a floating **arrow button** that scrolls to the top when clicked.
    * Add a **Contact Us button** that opens the contact page.
    * Add a **Shop Now button** that redirects to the products/store page.
    * Add an **About Us button** that opens the about page.
    
    Design:
    
    * Modern and clean
    * Mobile-friendly and responsive
    * Rounded buttons
    * Smooth animations
    * Must not block content
    
    Ensure smooth appearance animation
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bottom-sticky-nav-{{ ai_gen_id }} {
    display: block;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 999;
    transform: translateY(100%);
    opacity: 0;
    visibility: hidden;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, visibility 0.4s ease;
    pointer-events: none;
  }

  .ai-bottom-sticky-nav-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .ai-bottom-sticky-nav-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-bottom-sticky-nav-content-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.button_gap }}px;
    flex-wrap: wrap;
  }

  .ai-bottom-sticky-nav-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .ai-bottom-sticky-nav-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-bottom-sticky-nav-btn-scroll-{{ ai_gen_id }} {
    background-color: {{ block.settings.scroll_button_background }};
    color: {{ block.settings.scroll_button_text_color }};
    border-color: {{ block.settings.scroll_button_border_color }};
    width: {{ block.settings.scroll_button_size }}px;
    height: {{ block.settings.scroll_button_size }}px;
    padding: 0;
    border-radius: 50%;
  }

  .ai-bottom-sticky-nav-btn-scroll-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.scroll_button_hover_background }};
    color: {{ block.settings.scroll_button_hover_text_color }};
    border-color: {{ block.settings.scroll_button_hover_border_color }};
  }

  .ai-bottom-sticky-nav-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-bottom-sticky-nav-btn-scroll-{{ ai_gen_id }} .ai-bottom-sticky-nav-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-bottom-sticky-nav-content-{{ ai_gen_id }} {
      gap: {{ block.settings.button_gap_mobile }}px;
    }

    .ai-bottom-sticky-nav-btn-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px;
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }

    .ai-bottom-sticky-nav-btn-scroll-{{ ai_gen_id }} {
      width: {{ block.settings.scroll_button_size_mobile }}px;
      height: {{ block.settings.scroll_button_size_mobile }}px;
    }

    .ai-bottom-sticky-nav-icon-{{ ai_gen_id }} {
      width: 18px;
      height: 18px;
    }

    .ai-bottom-sticky-nav-btn-scroll-{{ ai_gen_id }} .ai-bottom-sticky-nav-icon-{{ ai_gen_id }} {
      width: 20px;
      height: 20px;
    }

    {% if block.settings.hide_text_mobile %}
      .ai-bottom-sticky-nav-btn-text-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<bottom-sticky-nav-{{ ai_gen_id }}
  class="ai-bottom-sticky-nav-{{ ai_gen_id }}"
  data-scroll-threshold="{{ block.settings.scroll_threshold }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-bottom-sticky-nav-container-{{ ai_gen_id }}">
    <div class="ai-bottom-sticky-nav-content-{{ ai_gen_id }}">
      {% if block.settings.show_scroll_to_top %}
        <button
          class="ai-bottom-sticky-nav-btn-{{ ai_gen_id }} ai-bottom-sticky-nav-btn-scroll-{{ ai_gen_id }}"
          aria-label="Scroll to top"
          data-scroll-to-top
        >
          <svg
            class="ai-bottom-sticky-nav-icon-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="18 15 12 9 6 15"></polyline>
          </svg>
        </button>
      {% endif %}

      {% if block.settings.show_contact_button and block.settings.contact_page != blank %}
        <a
          href="{{ block.settings.contact_page.url }}"
          class="ai-bottom-sticky-nav-btn-{{ ai_gen_id }}"
        >
          <svg
            class="ai-bottom-sticky-nav-icon-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          <span class="ai-bottom-sticky-nav-btn-text-{{ ai_gen_id }}">{{ block.settings.contact_button_text }}</span>
        </a>
      {% endif %}

      {% if block.settings.show_shop_button %}
        <a
          href="{{ block.settings.shop_button_link }}"
          class="ai-bottom-sticky-nav-btn-{{ ai_gen_id }}"
        >
          <svg
            class="ai-bottom-sticky-nav-icon-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          <span class="ai-bottom-sticky-nav-btn-text-{{ ai_gen_id }}">{{ block.settings.shop_button_text }}</span>
        </a>
      {% endif %}

      {% if block.settings.show_about_button and block.settings.about_page != blank %}
        <a
          href="{{ block.settings.about_page.url }}"
          class="ai-bottom-sticky-nav-btn-{{ ai_gen_id }}"
        >
          <svg
            class="ai-bottom-sticky-nav-icon-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
          <span class="ai-bottom-sticky-nav-btn-text-{{ ai_gen_id }}">{{ block.settings.about_button_text }}</span>
        </a>
      {% endif %}
    </div>
  </div>
</bottom-sticky-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class BottomStickyNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.scrollThreshold = parseInt(this.dataset.scrollThreshold) || 100;
        this.isVisible = false;
        this.scrollToTopBtn = this.querySelector('[data-scroll-to-top]');
      }

      connectedCallback() {
        this.setupScrollListener();
        this.setupScrollToTop();
      }

      setupScrollListener() {
        let ticking = false;

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              this.handleScroll();
              ticking = false;
            });
            ticking = true;
          }
        });

        this.handleScroll();
      }

      handleScroll() {
        const scrollHeight = document.documentElement.scrollHeight;
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const clientHeight = window.innerHeight;
        const distanceFromBottom = scrollHeight - (scrollTop + clientHeight);

        if (distanceFromBottom <= this.scrollThreshold) {
          this.show();
        } else {
          this.hide();
        }
      }

      show() {
        if (!this.isVisible) {
          this.classList.add('ai-visible-{{ ai_gen_id }}');
          this.isVisible = true;
        }
      }

      hide() {
        if (this.isVisible) {
          this.classList.remove('ai-visible-{{ ai_gen_id }}');
          this.isVisible = false;
        }
      }

      setupScrollToTop() {
        if (this.scrollToTopBtn) {
          this.scrollToTopBtn.addEventListener('click', () => {
            window.scrollTo({
              top: 0,
              behavior: 'smooth'
            });
          });
        }
      }
    }

    customElements.define('bottom-sticky-nav-{{ ai_gen_id }}', BottomStickyNav{{ ai_gen_id }});
  })();
</script>

