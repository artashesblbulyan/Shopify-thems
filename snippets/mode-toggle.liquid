{%- doc -%}
  Day / Night mode toggle. Toggles `data-ed-mode` on <html> and persists to localStorage.
  Render in the header.
{%- enddoc -%}

<button
  type="button"
  class="ed-mode-toggle"
  aria-label="Toggle day / night mode"
  data-ed-mode-toggle
>
  <span data-ed-mode-label>Night</span>
  <span class="ed-mode-toggle__dot" aria-hidden="true"></span>
</button>

<script>
  (function () {
    var html = document.documentElement;
    var stored = localStorage.getItem('ed-mode') || 'night';
    html.dataset.edMode = stored;

    function syncLabels() {
      var mode = html.dataset.edMode === 'day' ? 'Day' : 'Night';
      document.querySelectorAll('[data-ed-mode-label]').forEach(function (el) {
        el.textContent = mode;
      });
    }
    syncLabels();

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-ed-mode-toggle]');
      if (!btn) return;
      var next = html.dataset.edMode === 'night' ? 'day' : 'night';
      html.dataset.edMode = next;
      localStorage.setItem('ed-mode', next);
      syncLabels();
    });
  })();
</script>
