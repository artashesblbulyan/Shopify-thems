{%- doc -%}
  Site-wide editorial chrome: scroll progress bar, floating day/night toggle,
  and scroll-reveal initializer. Rendered once in theme.liquid.
{%- enddoc -%}

<div class="ed-scroll-progress" data-ed-scroll-progress aria-hidden="true"></div>
<div class="ed-site-aura" data-ed-site-aura aria-hidden="true"></div>

<div class="ed-smart-actions" data-ed-smart-actions aria-label="Quick actions">
  <a class="ed-smart-actions__btn" href="{{ routes.search_url }}" aria-label="Search">
    <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
      <circle cx="9" cy="9" r="5.5"></circle>
      <path d="M13.5 13.5L17 17"></path>
    </svg>
  </a>
  <a class="ed-smart-actions__btn ed-smart-actions__cart" href="{{ routes.cart_url }}" aria-label="Cart">
    <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
      <path d="M5.2 6.5h9.6l-.8 9H6z"></path>
      <path d="M7.4 6.5a2.6 2.6 0 0 1 5.2 0"></path>
    </svg>
    <span data-ed-cart-count>{{ cart.item_count }}</span>
  </a>
  <button class="ed-smart-actions__btn" type="button" data-ed-back-top aria-label="Back to top">
    <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
      <path d="M10 16V4"></path>
      <path d="M5.5 8.5L10 4l4.5 4.5"></path>
    </svg>
  </button>
</div>

<div class="ed-cart-toast" data-ed-cart-toast role="status" aria-live="polite" aria-atomic="true">
  <span class="ed-cart-toast__dot" aria-hidden="true"></span>
  <span data-ed-cart-toast-message>Added to cart.</span>
  <a href="{{ routes.cart_url }}">View cart</a>
</div>

<script>
  (function () {
    var html = document.documentElement;
    var reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function onReady(fn) {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fn);
      } else {
        fn();
      }
    }

    // Scroll progress
    var bar = document.querySelector('[data-ed-scroll-progress]');
    function updateScroll() {
      var doc = document.documentElement;
      var max = doc.scrollHeight - doc.clientHeight;
      if (!max) return;
      var pct = (doc.scrollTop / max) * 100;
      if (bar) bar.style.width = pct + '%';
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    window.addEventListener('resize', updateScroll);
    updateScroll();

    // Fixed header: expose its height so content can offset beneath it
    function setHeaderHeight() {
      var header = document.querySelector('.ed-header');
      if (!header) return;
      var h = Math.round(header.getBoundingClientRect().height);
      if (h > 0) html.style.setProperty('--ed-header-h', h + 'px');
    }
    setHeaderHeight();
    window.addEventListener('resize', setHeaderHeight);
    window.addEventListener('load', setHeaderHeight);
    onReady(setHeaderHeight);
    if (window.ResizeObserver) {
      var headerEl = document.querySelector('.ed-header');
      if (headerEl) new ResizeObserver(setHeaderHeight).observe(headerEl);
    }

    // Subtle live scroll state: sticky header depth + hero image drift
    var motionTicking = false;
    function updateLiveMotion() {
      var y = window.scrollY || document.documentElement.scrollTop || 0;
      html.classList.toggle('ed-has-scrolled', y > 14);
      html.classList.toggle('ed-show-smart-actions', y > 360);
      if (!reducedMotion) {
        html.style.setProperty('--ed-hero-img-parallax', (-Math.min(34, y * 0.035)).toFixed(2) + 'px');
        html.style.setProperty('--ed-scroll-ratio', Math.min(1, y / 520).toFixed(3));
      }
      motionTicking = false;
    }
    function requestLiveMotion() {
      if (motionTicking) return;
      motionTicking = true;
      requestAnimationFrame(updateLiveMotion);
    }
    window.addEventListener('scroll', requestLiveMotion, { passive: true });
    window.addEventListener('resize', requestLiveMotion);
    requestLiveMotion();

    // Cinematic page state: section focus and pointer-driven lighting.
    function bindPageMotion() {
      var sections = document.querySelectorAll('.ed-section');
      sections.forEach(function (section, index) {
        section.style.setProperty('--ed-section-index', index);
      });

      if ('IntersectionObserver' in window) {
        var sceneObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            entry.target.classList.toggle('ed-section-in-view', entry.isIntersecting);
          });
        }, { threshold: 0.18, rootMargin: '-8% 0px -18% 0px' });
        sections.forEach(function (section) { sceneObserver.observe(section); });
      } else {
        sections.forEach(function (section) { section.classList.add('ed-section-in-view'); });
      }

      if (reducedMotion || !window.matchMedia || !window.matchMedia('(pointer: fine)').matches) return;
      var pointerTicking = false;
      function updatePointer(event) {
        if (pointerTicking) return;
        pointerTicking = true;
        requestAnimationFrame(function () {
          html.style.setProperty('--ed-pointer-x', event.clientX + 'px');
          html.style.setProperty('--ed-pointer-y', event.clientY + 'px');
          pointerTicking = false;
        });
      }
      window.addEventListener('pointermove', updatePointer, { passive: true });
    }
    onReady(bindPageMotion);

    document.addEventListener('click', function (event) {
      var topButton = event.target.closest && event.target.closest('[data-ed-back-top]');
      if (!topButton) return;
      event.preventDefault();
      window.scrollTo({ top: 0, behavior: reducedMotion ? 'auto' : 'smooth' });
    });

    // Editorial AJAX add-to-cart feedback for custom product cards and product page.
    var cartToast = document.querySelector('[data-ed-cart-toast]');
    var cartToastMessage = cartToast && cartToast.querySelector('[data-ed-cart-toast-message]');
    var cartToastTimer = null;

    function showCartToast(message) {
      if (!cartToast) return;
      if (cartToastMessage) cartToastMessage.textContent = message || 'Added to cart.';
      window.clearTimeout(cartToastTimer);
      cartToast.classList.add('is-visible');
      cartToastTimer = window.setTimeout(function () {
        cartToast.classList.remove('is-visible');
      }, 3200);
    }

    function updateCartCount(count) {
      document.querySelectorAll('[data-ed-cart-count]').forEach(function (el) {
        el.textContent = count;
      });
    }

    function refreshCartCount() {
      return fetch('{{ routes.cart_url }}.js', {
        headers: { Accept: 'application/json' }
      }).then(function (response) {
        if (!response.ok) throw new Error('Cart refresh failed.');
        return response.json();
      }).then(function (cart) {
        updateCartCount(cart.item_count || 0);
        return cart;
      });
    }

    function cartAddEndpoint(form) {
      var action = form.getAttribute('action') || '{{ routes.cart_add_url }}';
      action = action.replace(/\/$/, '');
      return action.indexOf('.js') === -1 ? action + '.js' : action;
    }

    function getCartButton(form) {
      return form.querySelector('[data-ed-add-button], .ed-bestsellers__quick, button[type="submit"]');
    }

    function setCartButtonLabel(button, label) {
      if (!button) return;
      var labelNode = button.querySelector('[data-ed-add-label]');
      if (labelNode) {
        labelNode.textContent = label;
      } else {
        button.textContent = label;
      }
    }

    function restoreCartButton(button) {
      if (!button) return;
      button.classList.remove('is-loading', 'is-added', 'is-error');
      button.disabled = button.dataset.edWasDisabled === 'true';
      if (button.dataset.edOriginalLabel) {
        setCartButtonLabel(button, button.dataset.edOriginalLabel);
      }
      delete button.dataset.edOriginalLabel;
      delete button.dataset.edWasDisabled;
    }

    document.addEventListener('submit', function (event) {
      var form = event.target;
      if (!form || !(form.matches('.ed-bestsellers__form') || form.matches('[data-ed-product-form]'))) return;
      if (!window.fetch || !window.FormData) return;

      event.preventDefault();

      if (form.dataset.edAjaxBusy === 'true') return;
      form.dataset.edAjaxBusy = 'true';

      var button = getCartButton(form);
      var labelNode = button && (button.querySelector('[data-ed-add-label]') || button);
      if (button) {
        button.dataset.edOriginalLabel = labelNode ? labelNode.textContent.trim() : '';
        button.dataset.edWasDisabled = button.disabled ? 'true' : 'false';
        button.disabled = true;
        button.classList.remove('is-added', 'is-error');
        button.classList.add('is-loading');
        setCartButtonLabel(button, 'Adding...');
      }

      fetch(cartAddEndpoint(form), {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form)
      }).then(function (response) {
        if (response.ok) return response.json();
        return response.json().then(function (data) {
          throw new Error(data.description || data.message || 'Could not add to cart.');
        });
      }).then(function (item) {
        return refreshCartCount().then(function () {
          return item;
        });
      }).then(function (item) {
        if (button) {
          button.classList.remove('is-loading', 'is-error');
          button.classList.add('is-added');
          setCartButtonLabel(button, 'Added');
        }
        showCartToast(((item && item.title) || 'Item') + ' added to cart.');
        window.setTimeout(function () {
          restoreCartButton(button);
        }, 1300);
      }).catch(function (error) {
        if (button) {
          button.classList.remove('is-loading', 'is-added');
          button.classList.add('is-error');
          setCartButtonLabel(button, 'Try again');
          window.setTimeout(function () {
            restoreCartButton(button);
          }, 1800);
        }
        showCartToast(error.message || 'Could not add to cart.');
      }).finally(function () {
        form.dataset.edAjaxBusy = 'false';
      });
    });

    // Scroll reveal - IntersectionObserver, runs after DOM is ready
    function bindReveal() {
      var els = document.querySelectorAll('.ed-reveal, .ed-reveal-stagger');
      if (!('IntersectionObserver' in window)) {
        els.forEach(function (el) { el.classList.add('is-in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      els.forEach(function (el) { io.observe(el); });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindReveal);
    } else {
      bindReveal();
    }

    // Count-up numbers (data-ed-count="12000" data-ed-count-suffix="+")
    function bindCountUp() {
      var nums = document.querySelectorAll('[data-ed-count]');
      if (!nums.length || !('IntersectionObserver' in window)) return;
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var target = parseFloat(el.dataset.edCount) || 0;
          var prefix = el.dataset.edCountPrefix || '';
          var suffix = el.dataset.edCountSuffix || '';
          var dur = parseInt(el.dataset.edCountDuration || '1400', 10);
          var start = performance.now();
          function tick(now) {
            var t = Math.min(1, (now - start) / dur);
            var eased = 1 - Math.pow(1 - t, 3);
            var val = Math.round(target * eased);
            if (target >= 1000) {
              el.textContent = prefix + (val >= 1000 ? (val / 1000).toFixed(1).replace(/\.0$/, '') + 'K' : val) + suffix;
            } else {
              el.textContent = prefix + val + suffix;
            }
            if (t < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
          io.unobserve(el);
        });
      }, { threshold: 0.5 });
      nums.forEach(function (n) { io.observe(n); });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindCountUp);
    } else {
      bindCountUp();
    }

    // Product/card tilt. Kept shallow so it feels premium, not gimmicky.
    function bindCardTilt() {
      if (reducedMotion || !window.matchMedia || !window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
      var cards = document.querySelectorAll([
        '.ed-bestsellers__card',
        '.ed-bento__card',
        '.ed-collection__card',
        '.ed-search__card',
        '.ed-list-collections__card'
      ].join(','));

      cards.forEach(function (card) {
        card.classList.add('ed-can-tilt');

        card.addEventListener('pointermove', function (event) {
          var rect = card.getBoundingClientRect();
          var x = (event.clientX - rect.left) / rect.width - 0.5;
          var y = (event.clientY - rect.top) / rect.height - 0.5;
          card.style.setProperty('--ed-tilt-x', (-y * 4.5).toFixed(2) + 'deg');
          card.style.setProperty('--ed-tilt-y', (x * 5.5).toFixed(2) + 'deg');
          card.style.setProperty('--ed-glare-x', ((x + 0.5) * 100).toFixed(1) + '%');
          card.style.setProperty('--ed-glare-y', ((y + 0.5) * 100).toFixed(1) + '%');
          card.style.setProperty('--ed-shift-x', (-x * 8).toFixed(2) + 'px');
          card.style.setProperty('--ed-shift-y', (-y * 6).toFixed(2) + 'px');
          card.classList.add('is-tilting');
        });

        card.addEventListener('pointerleave', function () {
          card.classList.remove('is-tilting');
          card.style.setProperty('--ed-tilt-x', '0deg');
          card.style.setProperty('--ed-tilt-y', '0deg');
          card.style.setProperty('--ed-shift-x', '0px');
          card.style.setProperty('--ed-shift-y', '0px');
        });
      });
    }
    onReady(bindCardTilt);

    // Mobile collection filter bottom sheet
    function bindFilterSheet() {
      var sheet = document.querySelector('[data-ed-mfilter-sheet]');
      if (!sheet) return;
      // #MainContent has a transform, which traps position:fixed descendants
      // (the sheet would render at the bottom of the page instead of the
      // viewport). Portal the sheet to <body> so fixed positioning works.
      if (sheet.parentNode !== document.body) {
        document.body.appendChild(sheet);
      }
      function openSheet() {
        sheet.setAttribute('data-ed-open', '');
        sheet.setAttribute('aria-hidden', 'false');
        html.style.overflow = 'hidden';
      }
      function closeSheet() {
        sheet.removeAttribute('data-ed-open');
        sheet.setAttribute('aria-hidden', 'true');
        html.style.overflow = '';
      }
      document.addEventListener('click', function (e) {
        if (e.target.closest('[data-ed-mfilter-open]')) {
          e.preventDefault();
          openSheet();
        } else if (e.target.closest('[data-ed-mfilter-close]')) {
          closeSheet();
        }
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && sheet.hasAttribute('data-ed-open')) closeSheet();
      });
    }
    onReady(bindFilterSheet);

  })();
</script>
